@using DbExplorer.Services
@inject DensityState DensityState
@inject IJSRuntime JS

<button class="icon-btn @(DensityState.IsCompact ? "icon-btn--active" : "")" type="button"
        @onclick="Toggle" title="@Tooltip" aria-label="@Tooltip" aria-pressed="@DensityState.IsCompact.ToString().ToLowerInvariant()">
    @if (DensityState.IsCompact)
    {
        @* Tight rows — clicking returns to comfortable spacing *@
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M4 5.5h16M4 9.5h16M4 13.5h16M4 17.5h16" />
        </svg>
    }
    else
    {
        @* Relaxed rows — clicking switches to compact spacing *@
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    }
</button>

@code {
    private string Tooltip => DensityState.IsCompact ? "Comfortable rows" : "Compact rows";

    private async Task Toggle()
    {
        DensityState.Toggle();
        try { await JS.InvokeVoidAsync("dbExplorerSetDensity", DensityState.IsCompact); }
        catch { }
    }
}
