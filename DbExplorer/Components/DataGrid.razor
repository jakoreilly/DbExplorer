@using DbExplorer.Controllers
@using DbExplorer.Core.Interfaces
@using DbExplorer.Core.Models
@using Microsoft.AspNetCore.Components.Web
@inject IDataBrowsingService DataService
@inject NavigationManager Nav
@inject ILogger<DataGrid> Logger
@inject IJSRuntime JS

<div class="panel data-grid-panel">
    <div class="grid-toolbar">
        <button @onclick="PrevPage" disabled="@(pageNumber <= 1)" title="Previous page">← Prev</button>
        <span class="grid-page-info">@ToolbarPageInfo</span>
        <button @onclick="NextPage" disabled="@(!HasNextPage)" title="Next page">Next →</button>
        <select @bind="pageSize" @bind:after="ResetAndLoad" title="Rows per page" aria-label="Rows per page">
            <option value="25">25 rows</option>
            <option value="50">50 rows</option>
            <option value="100">100 rows</option>
            <option value="250">250 rows</option>
            <option value="500">500 rows</option>
        </select>
        @if (sortColumn is null)
        {
            <button @onclick="TogglePkSortDirection" title="Toggle primary-key sort direction">@PkSortLabel</button>
        }
        else
        {
            <button @onclick="ClearColumnSort" title="Clear column sort (return to PK)">✕ @sortColumn @ColSortArrow(sortColumn)</button>
        }
        @if (activeFilters.Count > 0)
        {
            <button @onclick="ClearFilters" title="Clear filters">✕ Clear filters (@activeFilters.Count)</button>
        }
        <span class="grid-toolbar-spacer"></span>
        <span class="csv-export-group">
            <select @bind="exportScope" class="csv-scope-select" title="Choose CSV export scope">
                <option value="page">This page</option>
                <option value="all">All rows</option>
            </select>
            <a class="csv-link" href="@CsvUrl" target="_blank" rel="noopener noreferrer">Export CSV</a>
        </span>
        @if (_copyFeedback is not null)
        {
            <span class="copy-toast">@_copyFeedback</span>
        }
    </div>

    @if (isLoading)
    {
        <div class="loading"><span class="spinner" aria-hidden="true"></span> Loading data…</div>
    }
    else if (error is not null)
    {
        <div class="error">@error <button @onclick="LoadData">Retry</button></div>
    }
    else if (rows is not null && rows.Count > 0)
    {
        <div class="grid-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="row-detail-col"></th>
                        @foreach (var col in columns)
                        {
                            <th class="@(sortColumn == col ? "sorted" : "")"
                                @onclick="() => SetColumnSort(col)"
                                title="Sort by @col">
                                @col @ColSortArrow(col)
                            </th>
                        }
                    </tr>
                    <tr class="filter-row">
                        <th class="row-detail-col"></th>
                        @foreach (var col in columns)
                        {
                            <th class="filter-cell">
                                <select class="filter-op" value="@FilterOp(col)" @onchange="e => SetFilterOp(col, e.Value?.ToString())">
                                    <option value="Contains">∗a∗</option>
                                    <option value="Equals">a=b</option>
                                    <option value="NotEquals">a≠b</option>
                                    <option value="GreaterThan">a&gt;b</option>
                                    <option value="LessThan">a&lt;b</option>
                                    <option value="Between">a..b</option>
                                    <option value="IsNull">NULL</option>
                                    <option value="IsNotNull">NOT NULL</option>
                                    <option value="StartsWith">a∗</option>
                                </select>
                                @if (FilterOp(col) == "Between")
                                {
                                    <input class="filter-input"
                                           value="@GetFilterValue(col)"
                                           @oninput="e => SetFilterValue(col, e.Value?.ToString())"
                                           @onkeydown="e => OnFilterKeyDown(col, e)"
                                           placeholder="Min"
                                           disabled="@IsFilterDisabled(col)" />
                                    <input class="filter-input"
                                           value="@GetFilterValue2(col)"
                                           @oninput="e => SetFilterValue2(col, e.Value?.ToString())"
                                           @onkeydown="e => OnFilterKeyDown(col, e)"
                                           placeholder="Max"
                                           disabled="@IsFilterDisabled(col)" />
                                }
                                else
                                {
                                    <input class="filter-input"
                                           value="@GetFilterValue(col)"
                                           @oninput="e => SetFilterValue(col, e.Value?.ToString())"
                                           @onkeydown="e => OnFilterKeyDown(col, e)"
                                           placeholder="Filter"
                                           disabled="@IsFilterDisabled(col)" />
                                }
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr class="@(selectedRowForDetail == row ? "row-selected" : "")">
                            <td class="row-detail-col">
                                <button class="row-detail-btn" @onclick="() => ToggleRowDetail(row)" title="View row detail">⊞</button>
                            </td>
                            @foreach (var col in columns)
                            {
                                var raw = row.Fields.TryGetValue(col, out var v) ? v : null;
                                var val = raw?.ToString() ?? "";
                                <td @onclick="() => CopyCell(val)" title="Click to copy" class="copyable-cell">
                                    @if (raw is null)
                                    {
                                        <span class="null-value">NULL</span>
                                    }
                                    else
                                    {
                                        @val
                                    }
                                </td>
                            }
                        </tr>
                        @if (selectedRowForDetail == row)
                        {
                            <tr class="row-detail-row">
                                <td colspan="@(columns.Count + 1)" class="row-detail-cell">
                                    <div class="row-detail-panel">
                                        <div class="row-detail-header">
                                            <strong>Row Detail</strong>
                                            <button @onclick="() => selectedRowForDetail = null" title="Close">✕</button>
                                        </div>
                                        <table class="row-detail-table">
                                            @foreach (var field in selectedRowForDetail.Fields)
                                            {
                                                <tr>
                                                    <td class="field-name">@field.Key</td>
                                                    <td class="field-value" @onclick="() => CopyCell(field.Value?.ToString() ?? string.Empty)" title="Click to copy">
                                                        @if (field.Value is null)
                                                        {
                                                            <span class="null-value">NULL</span>
                                                        }
                                                        else
                                                        {
                                                            @field.Value.ToString()
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else if (activeFilters.Count > 0)
    {
        <div class="empty-state">
            <span class="empty-state-icon" aria-hidden="true">▦</span>
            No rows matched the current filters.
            <div style="margin-top: 0.5rem;"><button @onclick="ClearFilters" type="button">Clear filters</button></div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <span class="empty-state-icon" aria-hidden="true">▦</span>
            This @(ObjectName) is empty — no rows to display.
        </div>
    }
</div>

@code {
    [Parameter] public string SchemaName { get; set; } = "";
    [Parameter] public string ObjectName { get; set; } = "";

    private int pageNumber = 1;
    private int pageSize = 50;
    private int totalCount = -1;   // -1 = unknown (EagerRowCount = false)
    private SortDirection pkSortDirection = SortDirection.Descending;
    private string? sortColumn;
    private SortDirection sortColumnDir = SortDirection.Ascending;
    private readonly Dictionary<string, string> columnFilters = [];
    private readonly Dictionary<string, string> filterOps = [];
    private List<ColumnFilter> activeFilters = [];
    private string exportScope = "page";
    private IReadOnlyList<DataRow>? rows;
    private List<string> columns = [];
    private DataRow? selectedRowForDetail;
    private bool isLoading = true;
    private string? error;
    private string? _copyFeedback;
    private System.Threading.CancellationTokenSource? _copyCts;

    private bool HasNextPage => totalCount == -1
        ? rows?.Count == pageSize   // if we got a full page there may be more
        : pageNumber < TotalPages;

    private int TotalPages => totalCount >= 0 && pageSize > 0
        ? (int)Math.Ceiling((double)totalCount / pageSize)
        : pageNumber + (rows?.Count == pageSize ? 1 : 0);

    private string ToolbarPageInfo => totalCount >= 0
        ? $"Page {pageNumber} of {TotalPages} ({totalCount:N0} rows)"
        : $"Page {pageNumber}";

    private string PkSortLabel => pkSortDirection == SortDirection.Descending ? "PK ↓" : "PK ↑";
    private string ColSortArrow(string col) =>
        sortColumn == col ? (sortColumnDir == SortDirection.Ascending ? "↑" : "↓") : "";

    private string FilterOp(string col) => filterOps.TryGetValue(col, out var op) ? op : "Contains";

    private string CsvUrl
    {
        get
        {
            var filterParam = activeFilters.Count > 0 ? $"&filters={Uri.EscapeDataString(DataController.EncodeFilters(activeFilters))}" : string.Empty;
            var url = $"/api/data/export-csv?schema={Uri.EscapeDataString(SchemaName)}&objectName={Uri.EscapeDataString(ObjectName)}&scope={Uri.EscapeDataString(exportScope)}&sortDir={(int)pkSortDirection}&sortCol={(sortColumn is null ? string.Empty : Uri.EscapeDataString(sortColumn))}&sortColDir={(int)sortColumnDir}{filterParam}";
            if (exportScope == "page")
                url += $"&page={pageNumber}&pageSize={pageSize}";
            return url;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        pageNumber = 1;
        pkSortDirection = SortDirection.Descending;
        sortColumn = null;
        sortColumnDir = SortDirection.Ascending;
        exportScope = "page";
        columnFilters.Clear();
        filterOps.Clear();
        activeFilters = [];
        selectedRowForDetail = null;
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        error = null;
        try
        {
            var paging = new PagingOptions
            {
                PageNumber = pageNumber,
                PageSize = pageSize,
                OrderByPrimaryKey = pkSortDirection,
                SortColumn = sortColumn,
                SortColumnDirection = sortColumnDir,
                Filters = activeFilters.Count > 0 ? activeFilters : null
            };

            var result = await DataService.GetPagedDataAsync(SchemaName, ObjectName, paging);
            rows = result.Items;
            totalCount = result.TotalCount;

            if (rows.Count > 0)
            {
                var newColumns = rows[0].Fields.Keys.ToList();
                foreach (var col in newColumns)
                {
                    if (!columnFilters.ContainsKey(col))
                        columnFilters[col] = string.Empty;
                    if (!filterOps.ContainsKey(col))
                        filterOps[col] = "Contains";
                }

                var staleColumns = columns.Where(c => !newColumns.Contains(c)).ToList();
                foreach (var col in staleColumns)
                {
                    columnFilters.Remove(col);
                    filterOps.Remove(col);
                }

                columns = newColumns;
            }
            else if (columns.Count == 0)
            {
                columns = [];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading data for {Schema}.{Object} page {Page}", SchemaName, ObjectName, pageNumber);
            error = "Failed to load data. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ResetAndLoad()
    {
        pageNumber = 1;
        await LoadData();
    }

    private async Task PrevPage()
    {
        if (pageNumber > 1) { pageNumber--; await LoadData(); }
    }

    private async Task NextPage()
    {
        if (HasNextPage) { pageNumber++; await LoadData(); }
    }

    private async Task TogglePkSortDirection()
    {
        sortColumn = null;
        pkSortDirection = pkSortDirection == SortDirection.Descending
            ? SortDirection.Ascending
            : SortDirection.Descending;
        pageNumber = 1;
        await LoadData();
    }

    private async Task SetColumnSort(string col)
    {
        if (sortColumn == col)
            sortColumnDir = sortColumnDir == SortDirection.Ascending ? SortDirection.Descending : SortDirection.Ascending;
        else
        {
            sortColumn = col;
            sortColumnDir = SortDirection.Ascending;
        }
        pageNumber = 1;
        await LoadData();
    }

    private async Task ClearColumnSort()
    {
        sortColumn = null;
        pageNumber = 1;
        await LoadData();
    }

    private async Task ApplyFilters()
    {
        activeFilters = columns
            .SelectMany(col =>
            {
                var rawValue = columnFilters.GetValueOrDefault(col);
                var op = filterOps.GetValueOrDefault(col, "Contains");
                var value = rawValue?.Trim() ?? string.Empty;
                if (string.IsNullOrWhiteSpace(value))
                    return Array.Empty<ColumnFilter>();

                if (op is "IsNull" or "IsNotNull")
                    return new[] { new ColumnFilter(col, value, Enum.Parse<ColumnFilterOperator>(op)) };

                if (op == "Between")
                {
                    var parts = value.Split('|', 2);
                    return parts.Length == 2 && !string.IsNullOrWhiteSpace(parts[0]) && !string.IsNullOrWhiteSpace(parts[1])
                        ? new[] { new ColumnFilter(col, parts[0].Trim(), ColumnFilterOperator.Between, parts[1].Trim()) }
                        : Array.Empty<ColumnFilter>();
                }

                return new[] { new ColumnFilter(col, value, Enum.Parse<ColumnFilterOperator>(op)) };
            })
            .ToList();

        pageNumber = 1;
        await LoadData();
    }

    private async Task ClearFilters()
    {
        columnFilters.Clear();
        filterOps.Clear();
        activeFilters = [];
        pageNumber = 1;
        await LoadData();
    }

    private string GetFilterValue(string col)
    {
        var value = columnFilters.GetValueOrDefault(col, string.Empty);
        var parts = value.Split('|', 2);
        return parts[0];
    }

    private string GetFilterValue2(string col)
    {
        var value = columnFilters.GetValueOrDefault(col, string.Empty);
        var parts = value.Split('|', 2);
        return parts.Length > 1 ? parts[1] : string.Empty;
    }

    private void SetFilterValue(string col, string? value)
    {
        var current = columnFilters.GetValueOrDefault(col, string.Empty);
        var parts = current.Split('|', 2);
        var second = parts.Length > 1 ? parts[1] : string.Empty;
        columnFilters[col] = $"{value ?? string.Empty}|{second}";
    }

    private void SetFilterValue2(string col, string? value)
    {
        var current = columnFilters.GetValueOrDefault(col, string.Empty);
        var parts = current.Split('|', 2);
        var first = parts.Length > 0 ? parts[0] : string.Empty;
        columnFilters[col] = $"{first}|{value ?? string.Empty}";
    }

    private void SetFilterOp(string col, string? op)
    {
        if (string.IsNullOrWhiteSpace(op))
            return;
        filterOps[col] = op;
    }

    private bool IsFilterDisabled(string col) => filterOps.GetValueOrDefault(col, "Contains") is "IsNull" or "IsNotNull";

    private async Task OnFilterKeyDown(string col, KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ApplyFilters();
    }

    private void ToggleRowDetail(DataRow row)
    {
        selectedRowForDetail = selectedRowForDetail == row ? null : row;
    }

    private async Task CopyCell(string value)
    {
        var ok = await JS.InvokeAsync<bool>("copyToClipboard", value);
        if (ok)
        {
            _copyCts?.Cancel();
            _copyCts = new System.Threading.CancellationTokenSource();
            _copyFeedback = "Copied!";
            StateHasChanged();
            try
            {
                await Task.Delay(1500, _copyCts.Token);
                _copyFeedback = null;
                StateHasChanged();
            }
            catch (TaskCanceledException) { }
        }
    }
}

