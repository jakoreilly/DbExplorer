@using DbExplorer.Services
@inject DatabaseSelectorState SelectorState
@inject IJSRuntime JS

<span class="db-selector-label">Server:</span>
<select class="database-selector" value="@CurrentName" @onchange="OnSelectionChanged" aria-label="Select database" title="Select database connection" @key="CurrentName">
    @foreach (var option in SelectorState.Options)
    {
        <option value="@option.Name">@option.Name</option>
    }
</select>

@code {
    private string CurrentName { get; set; } = string.Empty;
    private bool _initialStateRestored;

    protected override void OnInitialized()
    {
        CurrentName = SelectorState.Current.Name;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialStateRestored)
            return;

        _initialStateRestored = true;

        try
        {
            var saved = await JS.InvokeAsync<string?>("dbExplorerGetSelectedDatabase");
            if (!string.IsNullOrWhiteSpace(saved) && saved != SelectorState.Current.Name && SelectorState.TrySetCurrent(saved))
            {
                CurrentName = saved;
                StateHasChanged();
                // OnChange event notifies ObjectTree to reload — no forceLoad needed
            }
        }
        catch { }
    }

    private async Task OnSelectionChanged(ChangeEventArgs args)
    {
        var selected = args.Value?.ToString();
        if (selected is null)
            return;

        if (SelectorState.TrySetCurrent(selected))
        {
            CurrentName = selected;
            try
            {
                await JS.InvokeVoidAsync("dbExplorerSetSelectedDatabase", selected);
            }
            catch { }
            // OnChange event notifies ObjectTree to reload — no page reload needed
        }
    }
}
