@using static Microsoft.AspNetCore.Components.Web.RenderMode
@using DbExplorer.Options
@using Microsoft.Extensions.Options
@inject IOptions<ProfilerOptions> ProfilerOpts

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>DbExplorer</title>
    <link rel="icon" type="image/svg+xml"
          href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0' y1='0' x2='1' y2='1'%3E%3Cstop offset='0' stop-color='%232563eb'/%3E%3Cstop offset='1' stop-color='%237c3aed'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='32' height='32' rx='7' fill='url(%23g)'/%3E%3Cellipse cx='16' cy='10' rx='8' ry='3.4' fill='none' stroke='white' stroke-width='2'/%3E%3Cpath d='M8 10v12c0 1.9 3.6 3.4 8 3.4s8-1.5 8-3.4V10' fill='none' stroke='white' stroke-width='2'/%3E%3Cpath d='M8 16c0 1.9 3.6 3.4 8 3.4s8-1.5 8-3.4' fill='none' stroke='white' stroke-width='2'/%3E%3C/svg%3E" />
    <script>
        // Apply saved theme immediately to prevent flash on any page (including login)
        try {
            if (localStorage.getItem('dbexplorer_theme_dark') === '1') {
                document.documentElement.classList.add('theme-dark');
            }
        } catch (e) { }
    </script>
    <link rel="stylesheet" href="css/app.css" />
    <link href="_content/Z.Blazor.Diagrams/style.min.css" rel="stylesheet" />
    <link href="_content/Z.Blazor.Diagrams/default.styles.min.css" rel="stylesheet" />
    <!-- SRI hashes computed against cdnjs.cloudflare.com at the library versions pinned below.
         If you upgrade highlight.js or CodeMirror, recompute each hash with PowerShell:
           $b = (Invoke-WebRequest CDN_URL).Content
           "sha384-" + [Convert]::ToBase64String([SHA384]::Create().ComputeHash($b)) -->
    @if (ProfilerOpts.Value.EnableSyntaxHighlighting)
    {
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css"
              class="hljs-theme-light"
              integrity="sha384-eFTL69TLRZTkNfYZOLM+G04821K1qZao/4QLJbet1pP4tcF+fdXq/9CdqAbWRl/L"
              crossorigin="anonymous" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css"
              class="hljs-theme-dark"
              integrity="sha384-wH75j6z1lH97ZOpMOInqhgKzFkAInZPPSPlZpYKYTOqsaizPvhQZmAtLcPKXpLyH"
              crossorigin="anonymous" disabled />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.css"
              integrity="sha384-zaeBlB/vwYsDRSlFajnDd7OydJ0cWk+c2OWybl3eSUf6hW2EbhlCsQPqKr3gkznT"
              crossorigin="anonymous" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/theme/dracula.min.css"
              class="cm-theme-dark"
              integrity="sha384-ccdJwIIg/K0Ab6aXF4MPACh7ckk61tvQFTrfkhXZEALgAETURNZIAuQLcS/aPbrM"
              crossorigin="anonymous" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/hint/show-hint.min.css"
              integrity="sha384-TU/qRI67N04B589luYdn1ZMRIGgJic3GB1WsvLJTRh92VO26vpxI4dCKiDtsR4fw"
              crossorigin="anonymous" />
    }
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.server.js"></script>
    @if (ProfilerOpts.Value.EnableSyntaxHighlighting)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
                integrity="sha384-F/bZzf7p3Joyp5psL90p/p89AZJsndkSoGwRpXcZhleCWhd8SnRuoYo4d0yirjJp"
                crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.js"
                integrity="sha384-BEgQlz0fN4eG0n4jipmUe+nOg65hPY7L0E/lPVRaOPdzAfLPGEbXnpAodHtSnlwM"
                crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/sql/sql.min.js"
                integrity="sha384-HxXmA1hLc56V6Ja4yfcCwAprmbnS4tuvKYS0qKG3t6oxOFMflcnYq5fOnt6wVCda"
                crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/hint/show-hint.min.js"
                integrity="sha384-qCnKPgNYgVO8RO19jShRRAfU75+KVnN1cQy+8CPX/TTwJsUEJ/EpnwKx2UOyLx8c"
                crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/hint/sql-hint.min.js"
                integrity="sha384-x2NdW32on8wdeZesJC5KUk9Mb4RWo/H9mPCdwE2LyOlUOnU82Moona+nYiLbyRdO"
                crossorigin="anonymous"></script>
    }
    <script>
        // Recently-viewed objects persisted in localStorage (max 10 entries per server)
        window.dbExplorerAddRecent = function (schema, name, type, server) {
            try {
                const key = 'dbexplorer_recent';
                const existing = JSON.parse(localStorage.getItem(key) || '[]');
                const filtered = existing.filter(x => !(x.schemaName === schema && x.objectName === name && x.server === server));
                filtered.unshift({ schemaName: schema, objectName: name, objectType: type, server: server });
                localStorage.setItem(key, JSON.stringify(filtered.slice(0, 50)));
            } catch (e) { }
        };
        window.dbExplorerGetRecent = function (server) {
            try {
                const all = JSON.parse(localStorage.getItem('dbexplorer_recent') || '[]');
                return server ? all.filter(x => x.server === server) : all;
            }
            catch (e) { return []; }
        };
        // Pinned objects persisted in localStorage, keyed per server
        window.dbExplorerGetPinned = function (server) {
            try {
                const all = JSON.parse(localStorage.getItem('dbexplorer_pinned') || '[]');
                return server ? all.filter(x => x.server === server) : all;
            }
            catch (e) { return []; }
        };
        window.dbExplorerIsPinned = function (server, schema, name) {
            try {
                const all = JSON.parse(localStorage.getItem('dbexplorer_pinned') || '[]');
                return all.some(x => x.server === server && x.schemaName === schema && x.objectName === name);
            }
            catch (e) { return false; }
        };
        // Toggles pin state; returns true when the object is pinned after the call
        window.dbExplorerTogglePinned = function (server, schema, name, type) {
            try {
                const key = 'dbexplorer_pinned';
                const all = JSON.parse(localStorage.getItem(key) || '[]');
                const idx = all.findIndex(x => x.server === server && x.schemaName === schema && x.objectName === name);
                if (idx >= 0) {
                    all.splice(idx, 1);
                    localStorage.setItem(key, JSON.stringify(all));
                    return false;
                }
                all.push({ server: server, schemaName: schema, objectName: name, objectType: type });
                localStorage.setItem(key, JSON.stringify(all.slice(-100)));
                return true;
            }
            catch (e) { return false; }
        };
        // Table density preference (comfortable / compact)
        window.dbExplorerSetDensity = function (isCompact) {
            try { localStorage.setItem('dbexplorer_density_compact', isCompact ? '1' : '0'); }
            catch (e) { }
        };
        window.dbExplorerGetDensity = function () {
            try { return localStorage.getItem('dbexplorer_density_compact') === '1'; }
            catch (e) { return false; }
        };
        window.dbExplorerSetSelectedDatabase = function (name) {
            try { localStorage.setItem('dbexplorer_selected_database', name); }
            catch (e) { }
        };
        window.dbExplorerGetSelectedDatabase = function () {
            try { return localStorage.getItem('dbexplorer_selected_database'); }
            catch (e) { return null; }
        };
        window.dbExplorerSetTheme = function (isDark) {
            try {
                localStorage.setItem('dbexplorer_theme_dark', isDark ? '1' : '0');
                document.documentElement.classList.toggle('theme-dark', isDark);
                // Toggle hljs stylesheets
                var hljsLight = document.querySelector('.hljs-theme-light');
                var hljsDark = document.querySelector('.hljs-theme-dark');
                if (hljsLight) hljsLight.disabled = isDark;
                if (hljsDark) hljsDark.disabled = !isDark;
                // Re-highlight already-highlighted elements with the new theme
                if (window.hljs) {
                    document.querySelectorAll('[data-highlighted]').forEach(function (el) {
                        delete el.dataset.highlighted;
                        hljs.highlightElement(el);
                    });
                }
                // Update all CodeMirror editor themes
                document.querySelectorAll('.CodeMirror').forEach(function (wrap) {
                    if (wrap.CodeMirror) wrap.CodeMirror.setOption('theme', isDark ? 'dracula' : 'default');
                });
            }
            catch (e) { }
        };
        window.dbExplorerGetTheme = function () {
            try { return localStorage.getItem('dbexplorer_theme_dark') === '1'; }
            catch (e) { return false; }
        };
        // Trigger highlight.js on a container element
        window.hljsHighlight = function (el) {
            if (window.hljs && el) hljs.highlightElement(el);
        };
        // Highlight all unhighlighted code.language-sql elements inside a container
        window.hljsHighlightNew = function (container) {
            if (!window.hljs || !container) return;
            container.querySelectorAll('code.language-sql:not([data-highlighted])').forEach(function (el) {
                hljs.highlightElement(el);
            });
        };
        // Initialise a CodeMirror SQL editor inside host element
        window.initSqlEditor = function (host, isDark, dotNetRef, initialValue) {
            if (!host || !window.CodeMirror || host._cm) return;
            var hintsAvailable = !!(CodeMirror.hint && CodeMirror.hint.sql);
            var cm = CodeMirror(host, {
                mode: 'text/x-sql',
                theme: isDark ? 'dracula' : 'default',
                lineNumbers: true,
                tabSize: 2,
                indentWithTabs: false,
                lineWrapping: true,
                extraKeys: {
                    'Ctrl-Enter': function () { dotNetRef.invokeMethodAsync('TriggerRunQuery'); },
                    'F5': function () { dotNetRef.invokeMethodAsync('TriggerRunQuery'); },
                    'Ctrl-Space': function (editor) {
                        if (hintsAvailable) editor.showHint({ completeSingle: false });
                    }
                }
            });
            host._cm = cm;
            host._cmTables = host._cmTables || {};
            if (initialValue) cm.setValue(initialValue);

            // CodeMirror measures its gutter width on creation. Because our CSS overrides the
            // font-size/line-height (and the panel may still be laying out), the first measure
            // is stale and the code text overlaps the line-number gutter. Refresh after layout
            // settles to force a re-measure.
            requestAnimationFrame(function () { cm.refresh(); });
            setTimeout(function () { cm.refresh(); }, 120);

            if (hintsAvailable) {
                // Feed table/column metadata to the sql-hint addon on every popup.
                cm.setOption('hintOptions', {
                    get tables() { return host._cmTables; },
                    completeSingle: false
                });
                // Auto-open suggestions while typing identifiers or after "." (table.column).
                cm.on('inputRead', function (editor, change) {
                    if (editor.state.completionActive) return;
                    var t = change.text && change.text[0];
                    if (!t || !/^[A-Za-z_.À-ɏ]$/.test(t)) return;
                    // Don't pop up inside string literals or comments.
                    var token = editor.getTokenAt(editor.getCursor());
                    if (token.type === 'string' || token.type === 'comment') return;
                    editor.showHint({ completeSingle: false });
                });
            }
        };
        // Update the table/column dictionary used for autocomplete suggestions.
        window.setSqlEditorHints = function (host, tables) {
            if (!host) return;
            host._cmTables = tables || {};
        };
        // Bind F5 to run the query while the Profiler page is open. Bound at the document
        // level (not the profiler container) so F5 is intercepted regardless of where focus
        // is — otherwise F5 falls through to the browser's native reload and drops the circuit.
        window.dbExplorerBindProfilerF5 = function (container, dotNetRef) {
            if (!dotNetRef || window._dbExplorerF5Handler) return;
            var handler = function (e) {
                if (e.key !== 'F5' || e.ctrlKey || e.shiftKey || e.altKey || e.metaKey) return;
                e.preventDefault();
                e.stopPropagation();
                dotNetRef.invokeMethodAsync('TriggerRunQuery');
            };
            document.addEventListener('keydown', handler, true);
            window._dbExplorerF5Handler = handler;
        };
        window.dbExplorerUnbindProfilerF5 = function (container) {
            if (!window._dbExplorerF5Handler) return;
            document.removeEventListener('keydown', window._dbExplorerF5Handler, true);
            window._dbExplorerF5Handler = null;
        };
        window.refreshSqlEditor = function (host) {
            if (host && host._cm) host._cm.refresh();
        };
        window.getSqlEditorValue = function (host) {
            return host && host._cm ? host._cm.getValue() : '';
        };
        window.setSqlEditorValue = function (host, value) {
            if (host && host._cm) host._cm.setValue(value || '');
        };
        window.disposeSqlEditor = function (host) {
            if (host && host._cm) host._cm = null;
        };
        // Copy text to clipboard, returns true on success
        window.copyToClipboard = async function (text) {
            try { await navigator.clipboard.writeText(text); return true; }
            catch (e) { return false; }
        };
        // Trigger a browser download of in-memory text content (e.g. CSV)
        window.dbExplorerDownloadText = function (fileName, mimeType, content) {
            var blob = new Blob([content], { type: mimeType });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = fileName;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        };
    </script>
    <script src="_content/Z.Blazor.Diagrams/script.min.js"></script>
</body>

</html>
