@using static Microsoft.AspNetCore.Components.Web.RenderMode

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>DbExplorer</title>
    <script>
        // Apply saved theme immediately to prevent flash on any page (including login)
        try {
            if (localStorage.getItem('dbexplorer_theme_dark') === '1') {
                document.documentElement.classList.add('theme-dark');
            }
        } catch (e) { }
    </script>
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css" class="hljs-theme-light" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" class="hljs-theme-dark" disabled />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.server.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script>
        // Recently-viewed objects persisted in localStorage (max 10 entries per server)
        window.dbExplorerAddRecent = function (schema, name, type, server) {
            try {
                const key = 'dbexplorer_recent';
                const existing = JSON.parse(localStorage.getItem(key) || '[]');
                const filtered = existing.filter(x => !(x.schemaName === schema && x.objectName === name && x.server === server));
                filtered.unshift({ schemaName: schema, objectName: name, objectType: type, server: server });
                localStorage.setItem(key, JSON.stringify(filtered.slice(0, 50)));
            } catch (e) { }
        };
        window.dbExplorerGetRecent = function (server) {
            try {
                const all = JSON.parse(localStorage.getItem('dbexplorer_recent') || '[]');
                return server ? all.filter(x => x.server === server) : all;
            }
            catch (e) { return []; }
        };
        window.dbExplorerSetSelectedDatabase = function (name) {
            try { localStorage.setItem('dbexplorer_selected_database', name); }
            catch (e) { }
        };
        window.dbExplorerGetSelectedDatabase = function () {
            try { return localStorage.getItem('dbexplorer_selected_database'); }
            catch (e) { return null; }
        };
        window.dbExplorerSetTheme = function (isDark) {
            try {
                localStorage.setItem('dbexplorer_theme_dark', isDark ? '1' : '0');
                document.documentElement.classList.toggle('theme-dark', isDark);
            }
            catch (e) { }
        };
        window.dbExplorerGetTheme = function () {
            try { return localStorage.getItem('dbexplorer_theme_dark') === '1'; }
            catch (e) { return false; }
        };
        // Trigger highlight.js on a container element
        window.hljsHighlight = function (el) {
            if (window.hljs && el) hljs.highlightElement(el);
        };
        // Copy text to clipboard, returns true on success
        window.copyToClipboard = async function (text) {
            try { await navigator.clipboard.writeText(text); return true; }
            catch (e) { return false; }
        };
    </script>
</body>

</html>
