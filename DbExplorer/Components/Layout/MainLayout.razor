@inherits LayoutComponentBase
@using DbExplorer.Services
@using DbExplorer.Options
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.Extensions.Options
@inject ThemeState ThemeState
@inject DensityState DensityState
@inject IJSRuntime JS
@inject IOptions<QueryBuilderOptions> QBOpts
@implements IDisposable

<div class="layout @(ThemeState.IsDarkMode ? "theme-dark" : "theme-light") @(DensityState.IsCompact ? "density-compact" : "")" id="main-layout">
    <div class="signing-out-overlay" aria-hidden="true">Signing out…</div>
    <nav class="sidebar">
        <div class="sidebar-header">
            <a href="/" class="sidebar-title-link">
                <span class="brand-logo" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <ellipse cx="12" cy="6" rx="7" ry="2.8" />
                        <path d="M5 6v12c0 1.55 3.13 2.8 7 2.8s7-1.25 7-2.8V6" />
                        <path d="M5 12c0 1.55 3.13 2.8 7 2.8s7-1.25 7-2.8" />
                    </svg>
                </span>
                <span class="brand-text">
                    <span class="brand-name">DbExplorer</span>
                    <span class="brand-tag">Database Browser</span>
                </span>
            </a>
        </div>
        <nav class="sidebar-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="sidebar-nav-link">Explorer</NavLink>
            <NavLink href="/profiler" class="sidebar-nav-link">Profiler</NavLink>
            @if (QBOpts.Value.Enabled)
            {
                <NavLink href="/query-builder" class="sidebar-nav-link">Query Builder</NavLink>
            }
        </nav>
        <PinnedObjects />
        <RecentlyViewed />
        <ObjectTree />
    </nav>
    <main class="main-content">
        <div class="top-bar">
            <span class="top-bar-spacer"></span>
            <span class="db-selector-group">
                <DatabaseSelector />
            </span>
            <span class="top-bar-divider" aria-hidden="true"></span>
            <DensityToggle />
            <ThemeToggle />
            <span class="top-bar-divider" aria-hidden="true"></span>
            <form method="post" action="/logout" class="logout-form" @formname="logout-form"
                  onsubmit="document.getElementById('main-layout').classList.add('signing-out')">
                <AntiforgeryToken />
                <button type="submit">Sign Out</button>
            </form>
        </div>
        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        ThemeState.OnChange += HandleStateChanged;
        DensityState.OnChange += HandleStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var savedDark = await JS.InvokeAsync<bool>("dbExplorerGetTheme");
            ThemeState.SetDarkMode(savedDark);
            // Ensure html element class stays in sync (covers case where circuit reconnects)
            await JS.InvokeVoidAsync("dbExplorerSetTheme", savedDark);

            var savedCompact = await JS.InvokeAsync<bool>("dbExplorerGetDensity");
            DensityState.SetCompact(savedCompact);
        }
        catch { }
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeState.OnChange -= HandleStateChanged;
        DensityState.OnChange -= HandleStateChanged;
    }
}
