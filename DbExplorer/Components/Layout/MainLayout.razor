@inherits LayoutComponentBase
@using DbExplorer.Services
@using DbExplorer.Options
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.Extensions.Options
@inject ThemeState ThemeState
@inject DensityState DensityState
@inject IJSRuntime JS
@inject IOptions<QueryBuilderOptions> QBOpts
@inject IOptions<AnalyserOptions> AnalyserOpts
@implements IDisposable

<div class="layout @(ThemeState.IsDarkMode ? "theme-dark" : "theme-light") @(DensityState.IsCompact ? "density-compact" : "")" id="main-layout">
    <div class="signing-out-overlay" aria-hidden="true">Signing out…</div>
    <nav class="sidebar">
        <div class="sidebar-header">
            <a href="/" class="sidebar-title-link">
                <span class="brand-logo" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <ellipse cx="12" cy="6" rx="7" ry="2.8" />
                        <path d="M5 6v12c0 1.55 3.13 2.8 7 2.8s7-1.25 7-2.8V6" />
                        <path d="M5 12c0 1.55 3.13 2.8 7 2.8s7-1.25 7-2.8" />
                    </svg>
                </span>
                <span class="brand-text">
                    <span class="brand-name">DbExplorer</span>
                    <span class="brand-tag">Database Browser</span>
                </span>
            </a>
        </div>
        <nav class="sidebar-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="sidebar-nav-link" title="Explorer — browse database objects">
                <svg class="sidebar-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <ellipse cx="12" cy="5.5" rx="7.5" ry="2.8" />
                    <path d="M4.5 5.5v13c0 1.55 3.36 2.8 7.5 2.8s7.5-1.25 7.5-2.8v-13" />
                    <path d="M4.5 12c0 1.55 3.36 2.8 7.5 2.8s7.5-1.25 7.5-2.8" />
                </svg>
                <span class="sidebar-nav-label">Explorer</span>
            </NavLink>
            <NavLink href="/profiler" class="sidebar-nav-link" title="Profiler — run queries and watch live activity">
                <svg class="sidebar-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 12h4l2.5-7 4 14 2.5-7h5" />
                </svg>
                <span class="sidebar-nav-label">Profiler</span>
            </NavLink>
            <NavLink href="/search" class="sidebar-nav-link" title="Search — find tables and columns across all connections">
                <svg class="sidebar-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="7" />
                    <path d="m21 21-4.3-4.3" />
                </svg>
                <span class="sidebar-nav-label">Search</span>
            </NavLink>
            @if (QBOpts.Value.Enabled)
            {
                <NavLink href="/query-builder" class="sidebar-nav-link" title="Query Builder — build SELECT queries visually">
                    <svg class="sidebar-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="3" width="7" height="7" rx="1.5" />
                        <rect x="14" y="14" width="7" height="7" rx="1.5" />
                        <path d="M10 6.5h7.5v4" />
                        <path d="M14 17.5H6.5v-4" />
                    </svg>
                    <span class="sidebar-nav-label">Builder</span>
                </NavLink>
                <NavLink href="/diagram" class="sidebar-nav-link" title="Entity Map — every table and foreign key in the catalog">
                    <svg class="sidebar-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="8.5" y="2.5" width="7" height="5" rx="1.2" />
                        <rect x="2.5" y="16.5" width="7" height="5" rx="1.2" />
                        <rect x="14.5" y="16.5" width="7" height="5" rx="1.2" />
                        <path d="M12 7.5v4M12 11.5 6 16.5M12 11.5l6 5" />
                    </svg>
                    <span class="sidebar-nav-label">Entity Map</span>
                </NavLink>
            }
            @if (AnalyserOpts.Value.Enabled)
            {
                <NavLink href="/analyser" class="sidebar-nav-link" title="Systems Analyser — DB actions and errors">
                    <svg class="sidebar-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M3 21h18" />
                        <path d="M6 21v-8M11 21V6M16 21v-11M21 21v-5" />
                    </svg>
                    <span class="sidebar-nav-label">Analyser</span>
                </NavLink>
            }
        </nav>
        <PinnedObjects />
        <RecentlyViewed />
        <ObjectTree />
    </nav>
    <main class="main-content">
        <div class="top-bar">
            <span class="top-bar-spacer"></span>
            <span class="db-selector-group">
                <DatabaseSelector />
            </span>
            <span class="top-bar-divider" aria-hidden="true"></span>
            <DensityToggle />
            <ThemeToggle />
            <span class="top-bar-divider" aria-hidden="true"></span>
            <form method="post" action="/logout" class="logout-form" @formname="logout-form"
                  onsubmit="document.getElementById('main-layout').classList.add('signing-out')">
                <AntiforgeryToken />
                <button type="submit">Sign Out</button>
            </form>
        </div>
        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        ThemeState.OnChange += HandleStateChanged;
        DensityState.OnChange += HandleStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var savedDark = await JS.InvokeAsync<bool>("dbExplorerGetTheme");
            ThemeState.SetDarkMode(savedDark);
            // Ensure html element class stays in sync (covers case where circuit reconnects)
            await JS.InvokeVoidAsync("dbExplorerSetTheme", savedDark);

            var savedCompact = await JS.InvokeAsync<bool>("dbExplorerGetDensity");
            DensityState.SetCompact(savedCompact);
        }
        catch { }
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeState.OnChange -= HandleStateChanged;
        DensityState.OnChange -= HandleStateChanged;
    }
}
