@using DbExplorer.Core.Interfaces
@using DbExplorer.Core.Models
@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject IMetadataService MetadataService
@inject DatabaseSelectorState SelectorState
@inject NavigationManager Nav
@rendermode InteractiveServer
@implements IDisposable

<div class="object-tree">
    @if (catalogs is not null && (catalogs.Count > 1 || SelectorState.Current.Provider == DatabaseProvider.PostgreSql))
    {
        <div class="search-box">
            <select class="database-selector" value="@currentCatalog" @onchange="OnCatalogChanged" aria-label="Select catalog">
                @foreach (var catalog in catalogs)
                {
                    <option value="@catalog.CatalogName">@catalog.CatalogName</option>
                }
            </select>
        </div>
    }

    <div class="search-box">
        <input @bind="searchTerm" @bind:event="oninput" placeholder="Filter objects…" />
    </div>

    @if (!string.IsNullOrWhiteSpace(currentCatalog))
    {
        <div class="current-catalog">Connected catalog: <strong>@currentCatalog</strong></div>
        @if (SelectorState.Current.Provider == DatabaseProvider.PostgreSql &&
            (string.Equals(currentCatalog, "postgres", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentCatalog, "template0", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(currentCatalog, "template1", StringComparison.OrdinalIgnoreCase)))
        {
            <div class="catalog-warning">
                Connected to a PostgreSQL system database. If you expect user tables, select another catalog or update the connection string.
                @if (catalogs is not null && catalogs.Count > 1)
                {
                    <div class="catalog-warning-detail">Available databases: @string.Join(", ", catalogs.Select(c => c.CatalogName))</div>
                }
                else
                {
                    <div class="catalog-warning-detail">No other databases were detected on this server.</div>
                }
            </div>
        }
    }

    @if (isLoading)
    {
        <p class="loading">Loading…</p>
    }
    else if (loadError is not null)
    {
        <div class="error">Failed to load database objects: @loadError</div>
    }
    else if (schemas is not null)
    {
        foreach (var schema in schemas)
        {
            <div class="schema-node">
                <button class="schema-toggle" type="button" @onclick="() => ToggleSchema(schema.SchemaName)">
                    @(expandedSchemas.Contains(schema.SchemaName) ? "▾" : "▸") @schema.SchemaName
                </button>

                @if (expandedSchemas.Contains(schema.SchemaName) && objectsBySchema.TryGetValue(schema.SchemaName, out var objs))
                {
                    @if (objs.Count == 0)
                    {
                        <div class="schema-empty">No objects in this schema.</div>
                    }
                    else
                    {
                        foreach (var group in objs.GroupBy(o => o.ObjectType))
                        {
                            <div class="type-group">
                                <span class="type-label">@group.Key</span>
                                @foreach (var obj in group.Where(o =>
                                    string.IsNullOrWhiteSpace(searchTerm) ||
                                    o.ObjectName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
                                {
                                    <button class="object-node @(selectedObject == obj ? "selected" : "")" type="button"
                                            @onclick="() => SelectObject(obj)">
                                        @obj.ObjectName
                                    </button>
                                }
                            </div>
                        }
                    }
                }
            </div>
        }
    }
</div>

@code {
    private IReadOnlyList<SchemaInfo>? schemas;
    private Dictionary<string, IReadOnlyList<DatabaseObjectInfo>> objectsBySchema = new();
    private HashSet<string> expandedSchemas = new();
    private DatabaseObjectInfo? selectedObject;
    private IReadOnlyList<CatalogInfo>? catalogs;
    private string? currentCatalog;
    private string searchTerm = "";
    private bool isLoading = true;
    private string? loadError;

    [Inject] private ILogger<ObjectTree> Logger { get; set; } = default!;

    protected override void OnInitialized()
    {
        SelectorState.OnChange += HandleDatabaseChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadCatalogsAsync();
            await ReloadSchemasAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load schemas in ObjectTree");
            loadError = "Failed to load database objects. Check connection settings.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadCatalogsAsync()
    {
        var detected = await MetadataService.GetCurrentCatalogAsync();

        try
        {
            catalogs = await MetadataService.GetCatalogsAsync();
        }
        catch (Exception ex)
        {
            // If catalog enumeration is restricted, keep the UI usable with the current catalog only.
            Logger.LogWarning(ex, "Catalog enumeration is unavailable for the current connection.");
            catalogs = [new CatalogInfo(detected)];
        }

        var preferred = SelectorState.SelectedCatalog;

        if (!string.IsNullOrWhiteSpace(preferred) &&
            catalogs.Any(c => string.Equals(c.CatalogName, preferred, StringComparison.OrdinalIgnoreCase)))
        {
            currentCatalog = preferred;
            SelectorState.SetCatalog(currentCatalog);
            return;
        }

        // For PostgreSQL: if we'd default to a system database but user databases exist, prefer the first user database.
        if (SelectorState.Current.Provider == DatabaseProvider.PostgreSql
            && catalogs.Count > 1)
        {
            var systemDatabases = new[] { "postgres", "template0", "template1" };
            if (systemDatabases.Contains(detected, StringComparer.OrdinalIgnoreCase))
            {
                var userDb = catalogs.FirstOrDefault(c =>
                    !systemDatabases.Contains(c.CatalogName, StringComparer.OrdinalIgnoreCase));
                if (userDb is not null)
                {
                    currentCatalog = userDb.CatalogName;
                    SelectorState.SetCatalog(currentCatalog);
                    return;
                }
            }
        }

        currentCatalog = catalogs.FirstOrDefault(c => string.Equals(c.CatalogName, detected, StringComparison.OrdinalIgnoreCase))?.CatalogName
            ?? catalogs.FirstOrDefault()?.CatalogName
            ?? detected;

        SelectorState.SetCatalog(currentCatalog);
    }

    private async Task ReloadSchemasAsync()
    {
        schemas = await MetadataService.GetSchemasAsync();
        objectsBySchema.Clear();
        expandedSchemas.Clear();
        selectedObject = null;
    }

    private async Task OnCatalogChanged(ChangeEventArgs args)
    {
        var selected = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(selected) || string.Equals(selected, currentCatalog, StringComparison.OrdinalIgnoreCase))
            return;

        isLoading = true;
        loadError = null;
        SelectorState.SetCatalog(selected);
        currentCatalog = selected;

        try
        {
            await ReloadSchemasAsync();
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed switching catalog in ObjectTree");
            loadError = "Failed to switch catalog. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleSchema(string schemaName)
    {
        if (expandedSchemas.Contains(schemaName))
        {
            expandedSchemas.Remove(schemaName);
        }
        else
        {
            expandedSchemas.Add(schemaName);
            if (!objectsBySchema.ContainsKey(schemaName))
            {
                var objects = await MetadataService.GetObjectsAsync(schemaName);
                objectsBySchema[schemaName] = objects;
            }
        }
    }

    private void SelectObject(DatabaseObjectInfo obj)
    {
        selectedObject = obj;
        Nav.NavigateTo($"/explore/{Uri.EscapeDataString(obj.SchemaName)}/{Uri.EscapeDataString(obj.ObjectName)}");
    }

    private void HandleDatabaseChanged()
    {
        _ = InvokeAsync(async () =>
        {
            isLoading = true;
            loadError = null;
            schemas = null;
            objectsBySchema.Clear();
            expandedSchemas.Clear();
            selectedObject = null;
            StateHasChanged();
            try
            {
                await LoadCatalogsAsync();
                await ReloadSchemasAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to reload schemas after database switch");
                loadError = "Failed to load database objects. Check connection settings.";
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        });
    }

    public void Dispose()
    {
        SelectorState.OnChange -= HandleDatabaseChanged;
    }
}
