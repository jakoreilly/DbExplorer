@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject Microsoft.Extensions.Options.IOptions<DbExplorer.Options.AuthOptions> AuthOpts

<PageTitle>Sign In — DbExplorer</PageTitle>

<div class="login-container">
    <h2>DbExplorer — Sign In</h2>

    @if (Error)
    {
        <p class="error">Invalid username or password.</p>
    }
    @if (ErrorType == "google")
    {
        <p class="error">Google sign-in failed. Please try again.</p>
    }
    @if (ErrorType == "denied")
    {
        <p class="error">Your Google account is not authorised to access this application.</p>
    }

    @if (AuthOpts.Value.IsLocalLoginActive)
    {
    <form method="post" action="/api/login" @formname="login-form">
        <AntiforgeryToken />
        <div class="form-group">
            <label for="username">Username</label>
            <input id="username" name="username" type="text" autocomplete="username" required />
        </div>
        <div class="form-group">
            <label for="password">Password</label>
            <input id="password" name="password" type="password" autocomplete="current-password" required />
        </div>
        <button type="submit">Sign In</button>
    </form>
    }

    @if (AuthOpts.Value.IsLocalLoginActive && (AuthOpts.Value.Windows.Enabled || AuthOpts.Value.Google.Enabled))
    {
        <div class="login-divider"><span>or</span></div>
    }

    @if (AuthOpts.Value.Windows.Enabled)
    {
        <a class="login-external-btn" href="/auth/windows">Sign in with Windows</a>
    }

    @if (AuthOpts.Value.Google.Enabled)
    {
        <a class="login-external-btn login-google-btn" href="/auth/google">Sign in with Google</a>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    public bool Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ErrorType { get; set; }
}
