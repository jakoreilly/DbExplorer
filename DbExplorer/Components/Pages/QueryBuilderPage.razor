@page "/query-builder"
@using DbExplorer.Core.Interfaces
@using DbExplorer.Core.Models
@using DbExplorer.Options
@using DbExplorer.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Options
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject IMetadataService Metadata
@inject IQueryBuilderService QueryBuilder
@inject IAdHocQueryService AdHocService
@inject IQueryProfiler Profiler
@inject DatabaseSelectorState SelectorState
@inject DiagramInteropService DiagramInterop
@inject IOptions<QueryBuilderOptions> QBOpts
@inject IAuditLogger Audit
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Query Builder — DbExplorer</PageTitle>

@if (!QBOpts.Value.Enabled)
{
    <div class="profiler-error">The Query Builder is disabled. Set <code>QueryBuilder:Enabled = true</code> in appsettings.json to enable it.</div>
    return;
}

<div class="profiler-page">
    <div class="profiler-page-header">
        <h2>Query Builder</h2>
        <span class="profiler-connection-badge">
            @SelectorState.Current.Provider — @SelectorState.Current.Name@(SelectorState.SelectedCatalog is not null ? $" / {SelectorState.SelectedCatalog}" : "")
        </span>
    </div>

    <div class="profiler-readonly-notice">
        Read-only — only <code>SELECT</code> queries are generated. Column and table names are loaded from live schema metadata.
        @if (SelectorState.Current.Provider == DatabaseProvider.PostgreSql && SelectorState.SelectedCatalog is not null)
        {
            <span>Querying database <strong>@SelectorState.SelectedCatalog</strong> — use <code>schema.table</code> not <code>database.table</code>.</span>
        }
    </div>

    @* ── Mode tabs ────────────────────────────────────────────────────────── *@
    <div class="qb-mode-tabs">
        <button class="qb-mode-tab @(_activeMode == "canvas" ? "qb-mode-tab--active" : "")"
                @onclick='() => SwitchMode("canvas")'>◈ Visual Canvas</button>
        <button class="qb-mode-tab @(_activeMode == "form" ? "qb-mode-tab--active" : "")"
                @onclick='() => SwitchMode("form")'>⚙ Form Builder</button>
    </div>

    @if (_activeMode == "form")
    {
    @* ── Panel 1: Base Table ──────────────────────────────────────────────── *@
    <div class="profiler-panel @(_panel1Open ? "profiler-panel--open" : "")">
        <div class="profiler-panel-header" @onclick="() => _panel1Open = !_panel1Open">
            <span class="profiler-panel-toggle">@(_panel1Open ? "▼" : "▶")</span>
            <span>1. Base Table</span>
            @if (_selectedTable is not null)
            {
                <span class="profiler-panel-meta">@_selectedSchema.@_selectedTable (@_selectedColumnNames.Count col(s) selected)</span>
            }
        </div>
        @if (_panel1Open)
        {
            <div class="profiler-panel-body">
                <div class="qb-row">
                    <label class="qb-label">Schema</label>
                    @if (_schemas.Count == 0)
                    {
                        <span class="qb-hint">Loading…</span>
                    }
                    else
                    {
                        <select class="qb-select" @bind="_selectedSchema" @bind:after="OnSchemaChangedAsync">
                            <option value="">— select schema —</option>
                            @foreach (var s in _schemas)
                            {
                                <option value="@s.SchemaName">@s.SchemaName</option>
                            }
                        </select>
                    }

                    <label class="qb-label">Table / View</label>
                    @if (_isLoadingTables)
                    {
                        <span class="qb-hint">Loading…</span>
                    }
                    else
                    {
                        <select class="qb-select" @bind="_selectedTable" @bind:after="OnTableChangedAsync" disabled="@(!_tables.Any())">
                            <option value="">— select table —</option>
                            @foreach (var t in _tables)
                            {
                                <option value="@t.ObjectName">@t.ObjectName</option>
                            }
                        </select>
                    }
                </div>

                @if (_isLoadingCols)
                {
                    <p class="qb-hint" style="margin-top:0.5rem">Loading columns…</p>
                }
                else if (_columns.Count > 0)
                {
                    <div class="qb-col-toolbar">
                        <button class="profiler-btn" @onclick="SelectAllColumns">All</button>
                        <button class="profiler-btn" @onclick="SelectNoColumns">None</button>
                        <span class="qb-hint">@_selectedColumnNames.Count / @_columns.Count selected</span>
                    </div>
                    <div class="qb-col-grid">
                        @foreach (var col in _columns)
                        {
                            <label class="qb-col-label @(col.IsPrimaryKey ? "qb-col--pk" : "")">
                                <input type="checkbox"
                                       checked="@_selectedColumnNames.Contains(col.ColumnName)"
                                       @onchange="e => ToggleColumn(col.ColumnName, (bool)(e.Value ?? false))" />
                                <span class="qb-col-name">@col.ColumnName</span>
                                <span class="qb-col-type">@col.DataType</span>
                            </label>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @* ── Panel 2: JOINs ───────────────────────────────────────────────────── *@
    <div class="profiler-panel @(_panel2Open ? "profiler-panel--open" : "")">
        <div class="profiler-panel-header" @onclick="() => _panel2Open = !_panel2Open">
            <span class="profiler-panel-toggle">@(_panel2Open ? "▼" : "▶")</span>
            <span>2. JOINs</span>
            @if (_joins.Count > 0)
            {
                <span class="profiler-panel-meta">@_joins.Count join(s)</span>
            }
        </div>
        @if (_panel2Open)
        {
            <div class="profiler-panel-body">
                @if (_selectedTable is null)
                {
                    <p class="qb-hint">Select a base table first.</p>
                }
                else
                {
                    @foreach (var join in _joins)
                    {
                        <div class="qb-join-row" @key="join.Id">
                            <select class="qb-select qb-select--sm" @bind="join.JoinType" @bind:after="Recompile">
                                @foreach (var jt in Enum.GetValues<JoinType>())
                                {
                                    <option value="@jt">@jt.ToString().ToUpperInvariant() JOIN</option>
                                }
                            </select>
                            <span class="qb-hint">t0.</span>
                            <select class="qb-select qb-select--sm" @bind="join.SourceColumn" @bind:after="Recompile">
                                <option value="">— col —</option>
                                @foreach (var col in _columns)
                                {
                                    <option value="@col.ColumnName">@col.ColumnName</option>
                                }
                            </select>
                            <span class="qb-hint">=</span>
                            <select class="qb-select qb-select--sm" @bind="join.TargetSchema" @bind:after="() => OnJoinSchemaChangedAsync(join)">
                                <option value="">— schema —</option>
                                @foreach (var s in _schemas)
                                {
                                    <option value="@s.SchemaName">@s.SchemaName</option>
                                }
                            </select>
                            <select class="qb-select qb-select--sm" @bind="join.TargetTable" @bind:after="() => OnJoinTableChangedAsync(join)" disabled="@(string.IsNullOrEmpty(join.TargetSchema) || join.IsLoadingTargetTables)">
                                <option value="">— table —</option>
                                @foreach (var t in join.TargetTables)
                                {
                                    <option value="@t.ObjectName">@t.ObjectName</option>
                                }
                            </select>
                            <span class="qb-hint">.</span>
                            @if (join.IsLoadingTargetCols)
                            {
                                <span class="qb-hint">Loading…</span>
                            }
                            else
                            {
                                <select class="qb-select qb-select--sm" @bind="join.TargetColumn" @bind:after="Recompile" disabled="@(!join.TargetColumns.Any())">
                                    <option value="">— col —</option>
                                    @foreach (var col in join.TargetColumns)
                                    {
                                        <option value="@col.ColumnName">@col.ColumnName</option>
                                    }
                                </select>
                            }
                            <button class="profiler-btn profiler-btn--ghost qb-remove-btn" @onclick="() => RemoveJoin(join)">✕</button>
                        </div>
                    }
                    <button class="profiler-btn" @onclick="AddJoin">+ Add JOIN</button>
                }
            </div>
        }
    </div>

    @* ── Panel 3: WHERE Filters ───────────────────────────────────────────── *@
    <div class="profiler-panel @(_panel3Open ? "profiler-panel--open" : "")">
        <div class="profiler-panel-header" @onclick="() => _panel3Open = !_panel3Open">
            <span class="profiler-panel-toggle">@(_panel3Open ? "▼" : "▶")</span>
            <span>3. WHERE Filters</span>
            @if (_filters.Count > 0)
            {
                <span class="profiler-panel-meta">@_filters.Count filter(s)</span>
            }
        </div>
        @if (_panel3Open)
        {
            <div class="profiler-panel-body">
                @if (_selectedTable is null)
                {
                    <p class="qb-hint">Select a base table first.</p>
                }
                else
                {
                    @foreach (var filter in _filters)
                    {
                        var needsValue = filter.Operator is not (FilterOperator.IsNull or FilterOperator.IsNotNull);
                        <div class="qb-filter-row" @key="filter.Id">
                            <select class="qb-select qb-select--sm" @bind="filter.TableNodeId" @bind:after="Recompile">
                                @foreach (var (nodeId, cols) in GetAllTableColumns())
                                {
                                    <optgroup label="@nodeId">
                                        @foreach (var col in cols)
                                        {
                                            <option value="@nodeId|@col.ColumnName">@nodeId.@col.ColumnName</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <select class="qb-select qb-select--sm" @bind="filter.Operator" @bind:after="Recompile">
                                @foreach (var op in Enum.GetValues<FilterOperator>())
                                {
                                    <option value="@op">@OperatorLabel(op)</option>
                                }
                            </select>
                            @if (needsValue)
                            {
                                <input class="qb-input" type="text" placeholder="value" @bind="filter.Value" @bind:event="oninput" @bind:after="Recompile" />
                            }
                            <button class="profiler-btn profiler-btn--ghost qb-remove-btn" @onclick="() => RemoveFilter(filter)">✕</button>
                        </div>
                    }
                    <button class="profiler-btn" @onclick="AddFilter">+ Add Filter</button>
                }
            </div>
        }
    </div>

    @* ── Panel 4: Options ─────────────────────────────────────────────────── *@
    <div class="profiler-panel @(_panel4Open ? "profiler-panel--open" : "")">
        <div class="profiler-panel-header" @onclick="() => _panel4Open = !_panel4Open">
            <span class="profiler-panel-toggle">@(_panel4Open ? "▼" : "▶")</span>
            <span>4. Options</span>
        </div>
        @if (_panel4Open)
        {
            <div class="profiler-panel-body">
                <div class="qb-row">
                    <label class="qb-label">Row limit</label>
                    <input class="qb-input qb-input--sm" type="number" min="1" max="10000" @bind="_rowLimit" @bind:event="oninput" @bind:after="Recompile" />
                </div>
            </div>
        }
    </div>

    } @* end @if (_activeMode == "form") *@
    else
    {
    @* ── Visual Canvas ────────────────────────────────────────────────────── *@
    <div class="qb-canvas-layout">
        <div class="qb-canvas-sidebar">
            <h4 class="qb-canvas-sidebar__title">Add Tables</h4>
            <select class="qb-select" @bind="_canvasBrowserSchema" @bind:after="OnCanvasBrowserSchemaChangedAsync">
                <option value="">— schema —</option>
                @foreach (var s in _schemas)
                {
                    <option value="@s.SchemaName">@s.SchemaName</option>
                }
            </select>
            @if (_isLoadingCanvasTables)
            {
                <p class="qb-hint" style="margin-top:0.5rem">Loading…</p>
            }
            else if (_canvasBrowserTables.Any())
            {
                <div class="qb-sidebar-tables">
                    @foreach (var t in _canvasBrowserTables)
                    {
                        <div class="qb-sidebar-table"
                             draggable="true"
                             title="Drag onto the canvas"
                             @ondragstart="() => OnCanvasDragStart(_canvasBrowserSchema, t.ObjectName)">
                            @t.ObjectName
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(_canvasBrowserSchema))
            {
                <p class="qb-hint" style="margin-top:0.5rem">No tables found.</p>
            }
        </div>

        <div class="qb-canvas-area" @ondragover:preventDefault @ondrop="OnCanvasDrop">
            <CascadingValue Value="_blazorDiagram">
                <DiagramCanvas @key="_blazorDiagram"></DiagramCanvas>
            </CascadingValue>
        </div>
    </div>

    @* JOIN configuration — CanvasLinks captured once via 'is var' to avoid two allocations per render *@
    @if (CanvasLinks is var canvasLinks && canvasLinks.Count > 0)
    {
        <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
            <div class="profiler-panel-header" style="cursor:default">
                <span>JOIN Configuration</span>
                <span class="profiler-panel-meta">@canvasLinks.Count join(s)</span>
            </div>
            <div class="profiler-panel-body">
                @foreach (var link in canvasLinks)
                {
                    var srcNode = (link.Source as SinglePortAnchor)?.Port.Parent as TableDiagramNode;
                    var tgtNode = (link.Target as SinglePortAnchor)?.Port.Parent as TableDiagramNode;
                    if (srcNode is null || tgtNode is null || !_canvasJoinConfigs.TryGetValue(link.Id, out var cfg)) continue;
                    var srcCol = srcNode.GetColumnForPort((link.Source as SinglePortAnchor)!.Port) ?? cfg.SourceColumn;
                    var tgtCol = tgtNode.GetColumnForPort((link.Target as SinglePortAnchor)!.Port) ?? cfg.TargetColumn;
                    <div class="qb-join-row" @key="link.Id">
                        @* Column names are auto-detected from the port the user dragged from *@
                        <span class="qb-join-label">@srcNode.Alias.<strong>@srcCol</strong></span>
                        <select class="qb-select qb-select--sm" @bind="cfg.JoinType" @bind:after="RecompileCanvas">
                            @foreach (var jt in Enum.GetValues<JoinType>())
                            {
                                <option value="@jt">@jt.ToString().ToUpperInvariant() JOIN</option>
                            }
                        </select>
                        <span class="qb-join-label">@tgtNode.Alias.<strong>@tgtCol</strong></span>
                    </div>
                }
            </div>
        </div>
    }

    @* Row limit for canvas mode *@
    <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
        <div class="profiler-panel-header" style="cursor:default">
            <span>Options</span>
        </div>
        <div class="profiler-panel-body">
            <div class="qb-row">
                <label class="qb-label">Row limit</label>
                <input class="qb-input qb-input--sm" type="number" min="1" max="10000"
                       @bind="_rowLimit" @bind:event="oninput" @bind:after="RecompileCanvas" />
            </div>
        </div>
    </div>
    } @* end @else (canvas mode) *@

    @* ── SQL Preview ──────────────────────────────────────────────────────── *@
    <div class="qb-sql-preview">
        <div class="qb-sql-preview-header">
            <span>Generated SQL</span>
            <div class="qb-sql-actions">
                <button class="profiler-btn" @onclick="CopySqlAsync">@_copiedLabel</button>
                <button class="profiler-btn profiler-btn--primary" disabled="@(!CanRunQuery)"
                        @onclick="RunQueryAsync">
                    @(_isRunning ? "Running…" : "▶ Run Query")
                </button>
            </div>
        </div>
        <div class="profiler-plan">@_compiledSql</div>
    </div>

    @* ── Results ──────────────────────────────────────────────────────────── *@
    @if (_queryError is not null)
    {
        <div class="profiler-error" style="margin-top:0.75rem">@_queryError</div>
    }
    @if (_queryResult is not null)
    {
        <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
            <div class="profiler-panel-header" style="cursor:default">
                <span>Results</span>
                <span class="profiler-panel-meta">@_queryResult.Rows.Count row(s) · @_queryResult.ElapsedMs ms</span>
            </div>
            <div class="profiler-panel-body" style="padding:0">
                @if (_queryResult.Warning is not null)
                {
                    <div class="profiler-warning" style="margin:0.75rem 1rem 0">@_queryResult.Warning</div>
                }
                @if (_queryResult.Rows.Count == 0)
                {
                    <p class="profiler-empty">Query returned no rows.</p>
                }
                else
                {
                    <div class="profiler-table-scroll">
                        <table class="profiler-table">
                            <thead>
                                <tr>
                                    @foreach (var col in _queryResult.Columns)
                                    {
                                        <th>@col.Name</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _queryResult.Rows)
                                {
                                    <tr>
                                        @foreach (var col in _queryResult.Columns)
                                        {
                                            <td>@(row.TryGetValue(col.Name, out var v) ? v?.ToString() ?? "" : "")</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    // ── Mutable row state (not immutable records so Blazor can bind) ──────────

    private sealed class JoinRowState
    {
        public Guid Id { get; } = Guid.NewGuid();
        public JoinType JoinType { get; set; } = JoinType.Inner;
        public string SourceColumn { get; set; } = "";
        public string TargetSchema { get; set; } = "";
        /// <summary>Node alias for this join table, e.g. "t1".</summary>
        public string NodeId { get; set; } = "";
        public List<DatabaseObjectInfo> TargetTables { get; set; } = new();
        public string TargetTable { get; set; } = "";
        public List<ColumnInfo> TargetColumns { get; set; } = new();
        public string TargetColumn { get; set; } = "";
        public bool IsLoadingTargetTables { get; set; }
        public bool IsLoadingTargetCols { get; set; }
    }

    private sealed class FilterRowState
    {
        public Guid Id { get; } = Guid.NewGuid();
        /// <summary>Encoded as "nodeId|columnName" for binding to a single &lt;select&gt;.</summary>
        public string TableNodeId { get; set; } = "";
        public FilterOperator Operator { get; set; } = FilterOperator.Equals;
        public string Value { get; set; } = "";
    }

    /// <summary>Mutable config for a JOIN link on the visual canvas.</summary>
    private sealed class CanvasJoinConfig
    {
        public JoinType JoinType    { get; set; } = JoinType.Inner;
        public string SourceColumn  { get; set; } = "";
        public string TargetColumn  { get; set; } = "";
    }

    // ── Mode ──────────────────────────────────────────────────────────────────

    private string _activeMode = "canvas"; // "canvas" | "form"

    // ── Form-builder page state ───────────────────────────────────────────────

    private List<SchemaInfo> _schemas = new();
    private string _selectedSchema = "";
    private List<DatabaseObjectInfo> _tables = new();
    private string? _selectedTable;
    private List<ColumnInfo> _columns = new();
    private HashSet<string> _selectedColumnNames = new();
    private bool _isLoadingTables;
    private bool _isLoadingCols;

    private List<JoinRowState> _joins = new();
    private List<FilterRowState> _filters = new();
    private int _rowLimit = 1000;

    private string _compiledSql = "-- Select a table above to start building a query";
    private QueryResult? _queryResult;
    private string? _queryError;
    private bool _isRunning;
    private string _copiedLabel = "Copy SQL";
    private string _username = "anonymous";

    private bool _panel1Open = true;
    private bool _panel2Open = true;
    private bool _panel3Open = true;
    private bool _panel4Open = false;

    // ── Canvas state ──────────────────────────────────────────────────────────

    private BlazorDiagram _blazorDiagram = null!;
    private string _canvasBrowserSchema = "";
    private List<DatabaseObjectInfo> _canvasBrowserTables = new();
    private bool _isLoadingCanvasTables;
    private (string Schema, string TableName)? _draggedTableInfo;
    private int _nextNodeIndex;
    private readonly Dictionary<string, CanvasJoinConfig> _canvasJoinConfigs = new();

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        SelectorState.OnChange += HandleDatabaseChanged;
        DiagramInterop.OnNodeRemove  = RemoveCanvasNode;
        DiagramInterop.OnGraphChanged = () => InvokeAsync(() => { RecompileCanvas(); StateHasChanged(); });
        InitCanvas();
    }

    protected override async Task OnInitializedAsync()
    {
        _schemas = (await Metadata.GetSchemasAsync()).ToList();
        var authState = await AuthState.GetAuthenticationStateAsync();
        _username = authState.User.Identity?.Name ?? "anonymous";
    }

    private int _dbGeneration;

    private void HandleDatabaseChanged()
    {
        var gen = Interlocked.Increment(ref _dbGeneration);
        _ = InvokeAsync(async () =>
        {
            // Reset all state when the database connection changes
            _selectedSchema = "";
            _selectedTable = null;
            _tables = new();
            _columns = new();
            _selectedColumnNames = new();
            _joins = new();
            _filters = new();
            _compiledSql = "-- Add a table to start building a query";
            _queryResult = null;
            _queryError = null;
            _isLoadingTables = false;
            _isLoadingCols = false;

            // Reset canvas
            _canvasBrowserSchema = "";
            _canvasBrowserTables = new();
            _isLoadingCanvasTables = false;
            InitCanvas();

            var schemas = (await Metadata.GetSchemasAsync()).ToList();

            // Discard result if a newer switch happened while we were loading
            if (gen != _dbGeneration) return;

            _schemas = schemas;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SelectorState.OnChange -= HandleDatabaseChanged;
        DiagramInterop.OnNodeRemove  = null;
        DiagramInterop.OnGraphChanged = null;
        DisposeCanvas();
    }

    // ── Canvas initialisation / teardown ─────────────────────────────────────

    private void InitCanvas()
    {
        DisposeCanvas(); // unsubscribe from any prior diagram events

        _blazorDiagram = new BlazorDiagram();
        _blazorDiagram.RegisterComponent<TableDiagramNode, TableNodeWidget>();
        _blazorDiagram.Links.Added   += OnDiagramLinkAdded;
        _blazorDiagram.Links.Removed += OnDiagramLinkRemoved;
        _canvasJoinConfigs.Clear();
        _nextNodeIndex = 0;
    }

    private void DisposeCanvas()
    {
        if (_blazorDiagram is null) return;
        foreach (var link in _blazorDiagram.Links)
            link.Changed -= OnDiagramLinkChanged;
        _blazorDiagram.Links.Added   -= OnDiagramLinkAdded;
        _blazorDiagram.Links.Removed -= OnDiagramLinkRemoved;
    }

    // ── Mode switching ────────────────────────────────────────────────────────

    private void SwitchMode(string mode)
    {
        _activeMode = mode;
        if (mode == "canvas")
            RecompileCanvas();
        else
            Recompile();
    }

    // ── Canvas node removal ───────────────────────────────────────────────────

    private void RemoveCanvasNode(TableDiagramNode node)
    {
        // Remove any links connected to this node before removing the node itself
        var connectedLinks = _blazorDiagram.Links
            .Where(l => (l.Source is SinglePortAnchor s && s.Port.Parent == node) ||
                        (l.Target is SinglePortAnchor t && t.Port.Parent == node))
            .ToList();
        foreach (var link in connectedLinks)
            _blazorDiagram.Links.Remove(link);

        _blazorDiagram.Nodes.Remove(node);
        _ = InvokeAsync(() => { RecompileCanvas(); StateHasChanged(); });
    }

    // ── Canvas drag-and-drop ──────────────────────────────────────────────────

    private void OnCanvasDragStart(string schema, string tableName)
        => _draggedTableInfo = (schema, tableName);

    private async Task OnCanvasDrop(DragEventArgs e)
    {
        if (_draggedTableInfo is null) return;
        var (schema, tableName) = _draggedTableInfo.Value;
        _draggedTableInfo = null;

        var position = _blazorDiagram.GetRelativeMousePoint(e.ClientX, e.ClientY);
        var alias = $"t{_nextNodeIndex++}";
        var node  = new TableDiagramNode(alias, position)
        {
            SchemaName = schema,
            TableName  = tableName,
            IsLoading  = true
        };
        _blazorDiagram.Nodes.Add(node);

        try
        {
            var cols = (await Metadata.GetColumnsAsync(schema, tableName)).ToList();
            node.SetColumns(cols);
        }
        finally
        {
            node.IsLoading = false;
            node.Refresh();
        }

        RecompileCanvas();
        StateHasChanged();
    }

    private async Task OnCanvasBrowserSchemaChangedAsync()
    {
        _canvasBrowserTables = new();
        if (string.IsNullOrEmpty(_canvasBrowserSchema)) return;

        _isLoadingCanvasTables = true;
        StateHasChanged();
        try
        {
            _canvasBrowserTables = (await Metadata.GetObjectsAsync(_canvasBrowserSchema))
                .Where(o => o.ObjectType is "TABLE" or "VIEW")
                .ToList();
        }
        finally { _isLoadingCanvasTables = false; }
    }

    // ── Canvas link events ────────────────────────────────────────────────────

    private void OnDiagramLinkAdded(BaseLinkModel link)
        => link.Changed += OnDiagramLinkChanged;

    private void OnDiagramLinkChanged(Model model)
    {
        if (model is not BaseLinkModel link) return;
        // Only act when both ends are fully connected to ports; this filters out position/selection
        // change events that fire on every pixel of mouse movement during link dragging.
        if (link.Source is not SinglePortAnchor { Port: not null } srcAnchor ||
            link.Target is not SinglePortAnchor { Port: not null } tgtAnchor) return;

        if (!_canvasJoinConfigs.ContainsKey(link.Id))
        {
            var srcNode = srcAnchor.Port.Parent as TableDiagramNode;
            var tgtNode = tgtAnchor.Port.Parent as TableDiagramNode;
            _canvasJoinConfigs[link.Id] = new CanvasJoinConfig
            {
                // Auto-populate columns from the specific ports the user connected
                SourceColumn = srcNode?.GetColumnForPort(srcAnchor.Port) ?? srcNode?.Columns.FirstOrDefault()?.ColumnName ?? "",
                TargetColumn = tgtNode?.GetColumnForPort(tgtAnchor.Port) ?? tgtNode?.Columns.FirstOrDefault()?.ColumnName ?? ""
            };
        }

        _ = InvokeAsync(() => { RecompileCanvas(); StateHasChanged(); });
    }

    private void OnDiagramLinkRemoved(BaseLinkModel link)
    {
        link.Changed -= OnDiagramLinkChanged;
        _canvasJoinConfigs.Remove(link.Id);
        _ = InvokeAsync(() => { RecompileCanvas(); StateHasChanged(); });
    }

    // ── Canvas compilation ────────────────────────────────────────────────────

    private QueryGraph BuildGraphFromCanvas()
    {
        var tableNodes = _blazorDiagram.Nodes.OfType<TableDiagramNode>().ToList();
        if (!tableNodes.Any())
            return new QueryGraph(Array.Empty<QueryTableNode>(), Array.Empty<QueryJoinEdge>(),
                                  Array.Empty<QueryFilterNode>(), _rowLimit);

        var tables = tableNodes
            .Select(n => new QueryTableNode(
                Id: n.Alias,
                SchemaName: n.SchemaName,
                TableName: n.TableName,
                SelectedColumns: n.SelectedColumns.ToList()))
            .ToList();

        var joins = new List<QueryJoinEdge>();
        var seenPairs = new HashSet<(string, string)>();
        foreach (var link in _blazorDiagram.Links)
        {
            if (link.Source is not SinglePortAnchor srcAnchor || link.Target is not SinglePortAnchor tgtAnchor) continue;
            if (srcAnchor.Port.Parent is not TableDiagramNode srcNode)                                       continue;
            if (tgtAnchor.Port.Parent is not TableDiagramNode tgtNode)                                       continue;
            if (!_canvasJoinConfigs.TryGetValue(link.Id, out var cfg))                    continue;
            if (string.IsNullOrEmpty(cfg.SourceColumn) || string.IsNullOrEmpty(cfg.TargetColumn)) continue;

            // Skip duplicate joins between the same table pair (same pair in either direction → one JOIN)
            var pairKey = (srcNode.Alias, tgtNode.Alias);
            var reversePairKey = (tgtNode.Alias, srcNode.Alias);
            if (seenPairs.Contains(pairKey) || seenPairs.Contains(reversePairKey)) continue;
            seenPairs.Add(pairKey);

            joins.Add(new QueryJoinEdge(
                JoinType: cfg.JoinType,
                SourceNodeId: srcNode.Alias,
                SourceColumn: cfg.SourceColumn,
                TargetNodeId: tgtNode.Alias,
                TargetColumn: cfg.TargetColumn));
        }

        return new QueryGraph(tables, joins, Array.Empty<QueryFilterNode>(), _rowLimit);
    }

    private void RecompileCanvas()
    {
        var graph = BuildGraphFromCanvas();
        if (!graph.Tables.Any())
        {
            _compiledSql = "-- Drop a table onto the canvas to start building a query";
            return;
        }
        try
        {
            var (sql, _) = QueryBuilder.Compile(graph);
            _compiledSql = sql;
        }
        catch (Exception ex)
        {
            _compiledSql = $"-- Compilation error: {ex.Message}";
        }
    }

    // ── Canvas helpers ────────────────────────────────────────────────────────

    private IReadOnlyList<BaseLinkModel> CanvasLinks =>
        _blazorDiagram.Links
            .Where(l => l.Source is SinglePortAnchor spa && l.Target is SinglePortAnchor tpa
                     && spa.Port.Parent is TableDiagramNode && tpa.Port.Parent is TableDiagramNode)
            .ToList();

    // ── Run Query guard ───────────────────────────────────────────────────────

    private bool CanRunQuery =>
        !_isRunning && (
            (_activeMode == "form"   && _selectedTable is not null) ||
            (_activeMode == "canvas" && _blazorDiagram.Nodes.OfType<TableDiagramNode>().Any()));

    // ── Base table selectors ──────────────────────────────────────────────────

    private async Task OnSchemaChangedAsync()
    {
        _selectedTable = null;
        _tables = new();
        _columns = new();
        _selectedColumnNames = new();
        _joins = new();
        _filters = new();
        Recompile();

        if (string.IsNullOrEmpty(_selectedSchema)) return;

        _isLoadingTables = true;
        StateHasChanged();
        try
        {
            _tables = (await Metadata.GetObjectsAsync(_selectedSchema))
                .Where(o => o.ObjectType is "TABLE" or "VIEW")
                .ToList();
        }
        finally
        {
            _isLoadingTables = false;
        }
    }

    private async Task OnTableChangedAsync()
    {
        _columns = new();
        _selectedColumnNames = new();
        _joins = new();
        _filters = new();
        Recompile();

        if (string.IsNullOrEmpty(_selectedSchema) || string.IsNullOrEmpty(_selectedTable)) return;

        _isLoadingCols = true;
        StateHasChanged();
        try
        {
            _columns = (await Metadata.GetColumnsAsync(_selectedSchema, _selectedTable)).ToList();
            _selectedColumnNames = _columns.Select(c => c.ColumnName).ToHashSet();
        }
        finally
        {
            _isLoadingCols = false;
        }

        Recompile();
    }

    private void ToggleColumn(string columnName, bool selected)
    {
        if (selected) _selectedColumnNames.Add(columnName);
        else _selectedColumnNames.Remove(columnName);
        Recompile();
    }

    private void SelectAllColumns()
    {
        _selectedColumnNames = _columns.Select(c => c.ColumnName).ToHashSet();
        Recompile();
    }

    private void SelectNoColumns()
    {
        _selectedColumnNames = new();
        Recompile();
    }

    // ── JOIN management ───────────────────────────────────────────────────────

    private void AddJoin()
    {
        var idx = _joins.Count + 1;
        _joins.Add(new JoinRowState { NodeId = $"t{idx}" });
    }

    private void RemoveJoin(JoinRowState join)
    {
        _joins.Remove(join);
        // Reassign node IDs sequentially
        for (var i = 0; i < _joins.Count; i++)
            _joins[i].NodeId = $"t{i + 1}";
        Recompile();
    }

    private async Task OnJoinSchemaChangedAsync(JoinRowState join)
    {
        join.TargetTable = "";
        join.TargetTables = new();
        join.TargetColumn = "";
        join.TargetColumns = new();
        Recompile();

        if (string.IsNullOrEmpty(join.TargetSchema)) return;

        join.IsLoadingTargetTables = true;
        StateHasChanged();
        try
        {
            join.TargetTables = (await Metadata.GetObjectsAsync(join.TargetSchema))
                .Where(o => o.ObjectType is "TABLE" or "VIEW")
                .ToList();
        }
        finally
        {
            join.IsLoadingTargetTables = false;
        }
    }

    private async Task OnJoinTableChangedAsync(JoinRowState join)
    {
        join.TargetColumn = "";
        join.TargetColumns = new();
        Recompile();

        if (string.IsNullOrEmpty(join.TargetSchema) || string.IsNullOrEmpty(join.TargetTable)) return;

        join.IsLoadingTargetCols = true;
        StateHasChanged();
        try
        {
            join.TargetColumns = (await Metadata.GetColumnsAsync(join.TargetSchema, join.TargetTable)).ToList();
        }
        finally
        {
            join.IsLoadingTargetCols = false;
        }

        Recompile();
    }

    // ── Filter management ─────────────────────────────────────────────────────

    private void AddFilter()
    {
        // Don't allow adding a filter until columns are loaded (prevents empty-column SQL fragments)
        if (!_columns.Any()) return;
        _filters.Add(new FilterRowState { TableNodeId = $"t0|{_columns[0].ColumnName}" });
    }

    private void RemoveFilter(FilterRowState filter)
    {
        _filters.Remove(filter);
        Recompile();
    }

    // ── Compilation ───────────────────────────────────────────────────────────

    private void Recompile()
    {
        if (string.IsNullOrEmpty(_selectedTable))
        {
            _compiledSql = "-- Select a table above to start building a query";
            return;
        }

        var graph = BuildGraph();
        try
        {
            var (sql, _) = QueryBuilder.Compile(graph);
            _compiledSql = sql;
        }
        catch (Exception ex)
        {
            _compiledSql = $"-- Compilation error: {ex.Message}";
        }
    }

    private QueryGraph BuildGraph()
    {
        // Base table node
        var baseNode = new QueryTableNode(
            Id: "t0",
            SchemaName: _selectedSchema,
            TableName: _selectedTable!,
            SelectedColumns: _columns
                .Where(c => _selectedColumnNames.Contains(c.ColumnName))
                .Select(c => c.ColumnName)
                .ToList()
        );

        // Join nodes — no columns selected by default; user must explicitly choose them (prevents
        // a JOIN added for filtering from polluting SELECT with unwanted columns)
        var joinNodes = _joins
            .Where(j => !string.IsNullOrEmpty(j.TargetSchema) && !string.IsNullOrEmpty(j.TargetTable))
            .Select(j => new QueryTableNode(
                Id: j.NodeId,
                SchemaName: j.TargetSchema,
                TableName: j.TargetTable,
                SelectedColumns: Array.Empty<string>()))
            .ToList();

        var tables = new List<QueryTableNode> { baseNode };
        tables.AddRange(joinNodes);

        // Join edges
        var joinEdges = _joins
            .Where(j => !string.IsNullOrEmpty(j.SourceColumn) && !string.IsNullOrEmpty(j.TargetColumn)
                     && !string.IsNullOrEmpty(j.TargetSchema) && !string.IsNullOrEmpty(j.TargetTable))
            .Select(j => new QueryJoinEdge(
                JoinType: j.JoinType,
                SourceNodeId: "t0",
                SourceColumn: j.SourceColumn,
                TargetNodeId: j.NodeId,
                TargetColumn: j.TargetColumn))
            .ToList();

        // Filter nodes
        var filterNodes = _filters
            .Select(f =>
            {
                var parts = f.TableNodeId.Split('|', 2);
                if (parts.Length != 2 || string.IsNullOrEmpty(parts[1])) return null;
                return new QueryFilterNode(
                    NodeId: parts[0],
                    Column: parts[1],
                    Operator: f.Operator,
                    Value: string.IsNullOrEmpty(f.Value) ? null : f.Value);
            })
            .Where(f => f is not null)
            .Select(f => f!)
            .ToList();

        return new QueryGraph(tables, joinEdges, filterNodes, _rowLimit > 0 ? _rowLimit : 1000);
    }

    // ── Execution ─────────────────────────────────────────────────────────────

    private async Task RunQueryAsync()
    {
        if (!CanRunQuery) return;

        _isRunning = true;
        _queryError = null;
        _queryResult = null;
        StateHasChanged();

        try
        {
            var result = await AdHocService.ExecuteQueryAsync(_compiledSql, _rowLimit > 0 ? _rowLimit : 1000);
            _queryResult = result;
            Profiler.Record(SelectorState.Current.Provider.ToString(), _compiledSql, result.ElapsedMs, result.Rows.Count);
            Audit.Log(new AuditEvent(DateTimeOffset.UtcNow, _username, AuditAction.AdHocQuery,
                null, null, result.Rows.Count, result.ElapsedMs, Sql: _compiledSql));
        }
        catch (Exception ex)
        {
            _queryError = ex.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private async Task CopySqlAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _compiledSql);
            _copiedLabel = "Copied!";
            StateHasChanged();
            await Task.Delay(1500);
            _copiedLabel = "Copy SQL";
        }
        catch { /* clipboard API not available */ }
    }

    /// <summary>Returns all available (nodeId, columns) pairs for filter dropdowns.</summary>
    private IEnumerable<(string NodeId, IReadOnlyList<ColumnInfo> Columns)> GetAllTableColumns()
    {
        yield return ("t0", _columns);
        foreach (var join in _joins.Where(j => j.TargetColumns.Count > 0))
            yield return (join.NodeId, join.TargetColumns);
    }

    private static string OperatorLabel(FilterOperator op) => op switch
    {
        FilterOperator.Equals             => "=",
        FilterOperator.NotEquals          => "≠",
        FilterOperator.GreaterThan        => ">",
        FilterOperator.GreaterThanOrEqual => "≥",
        FilterOperator.LessThan           => "<",
        FilterOperator.LessThanOrEqual    => "≤",
        FilterOperator.Like               => "LIKE",
        FilterOperator.NotLike            => "NOT LIKE",
        FilterOperator.IsNull             => "IS NULL",
        FilterOperator.IsNotNull          => "IS NOT NULL",
        _                                 => op.ToString()
    };
}
