@page "/diagram"
@using DbExplorer.Core.Interfaces
@using DbExplorer.Core.Layout
@using DbExplorer.Options
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Options
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject IMetadataService Metadata
@inject DatabaseSelectorState SelectorState
@inject DiagramInteropService DiagramInterop
@inject IOptions<QueryBuilderOptions> QBOpts
@inject NavigationManager Nav
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Entity Map — DbExplorer</PageTitle>

@if (!QBOpts.Value.Enabled)
{
    <div class="profiler-error">Entity Map requires Query Builder to be enabled. Set <code>QueryBuilder:Enabled = true</code> in appsettings.json.</div>
    return;
}

<div class="profiler-page">
    <div class="profiler-page-header">
        <h2>Entity Map</h2>
        <span class="profiler-connection-badge">
            @SelectorState.Current.Provider — @SelectorState.Current.Name@(SelectorState.SelectedCatalog is not null ? $" / {SelectorState.SelectedCatalog}" : "")
        </span>
    </div>

    <div class="profiler-readonly-notice">
        A read-only map of your database: every table in the current catalog and the foreign keys
        that connect them. Use the schema filter or search to focus, and click a table to expand its columns.
    </div>

    @if (_isLoading)
    {
        <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
            <div class="profiler-panel-body">
                <p class="qb-hint"><span class="spinner" aria-hidden="true"></span>Reading tables and relationships…</p>
            </div>
        </div>
    }
    else if (_allObjects.Count == 0)
    {
        <div class="empty-state" style="margin-top:0.75rem">
            No tables found in this catalog. Check that the selected database and your permissions are correct.
        </div>
    }
    else
    {
        <div class="emap-toolbar">
            <div class="emap-toolbar-row">
                <input class="qb-input" style="max-width:220px" placeholder="Search tables (all schemas)…" aria-label="Search tables"
                       @bind="_searchTerm" @bind:event="oninput" @bind:after="OnSearchChanged" />
                @if (_focusRootId is not null)
                {
                    <div class="emap-toolbar-group">
                        <span class="diagram-hint">Focused on @_focusRootId</span>
                        <select class="qb-select" style="max-width:90px" @bind="_focusHops" @bind:after="RebuildMap">
                            <option value="1">1 hop</option>
                            <option value="2">2 hops</option>
                            <option value="3">3 hops</option>
                        </select>
                        <button class="profiler-btn profiler-btn--ghost profiler-btn--sm" @onclick="ClearFocus">Show all</button>
                    </div>
                }
                <span class="diagram-hint" style="margin-left:auto">@_visibleTableCount / @_allObjects.Count table(s) shown</span>
            </div>
            <div class="emap-toolbar-row">
                <label class="diagram-label">Schemas</label>
                @foreach (var schema in _schemaNames)
                {
                    <label class="tnode__col" style="cursor:pointer">
                        <input type="checkbox" checked="@_selectedSchemas.Contains(schema)"
                               @onchange="e => ToggleSchema(schema, (bool)(e.Value ?? false))" />
                        <span>@schema</span>
                    </label>
                }
            </div>
        </div>

        @if (_tooManyTables)
        {
            <div class="empty-state" style="margin-top:0.75rem">
                This selection has @_effectiveTables.Count tables — too many to draw at once. Narrow the
                search, pick fewer schemas, or focus a table to map its neighborhood.
            </div>
        }
        else if (_effectiveTables.Count == 0)
        {
            <div class="empty-state" style="margin-top:0.75rem">
                @(string.IsNullOrWhiteSpace(_searchTerm)
                    ? "No schemas selected — tick one or more schemas above to draw the map."
                    : "No tables match your search.")
            </div>
        }
        else
        {
            <div class="diagram-canvas-area" style="margin-top:0.75rem">
                @if (_diagramReady && _blazorDiagram is not null)
                {
                    <CascadingValue Value="_blazorDiagram">
                        <DiagramCanvas @key="_blazorDiagram"></DiagramCanvas>
                    </CascadingValue>
                }
                else
                {
                    <div class="qb-hint">Waiting for the diagram canvas to initialize…</div>
                }
            </div>

            @if (_linksSuppressed)
            {
                <p class="diagram-hint" style="margin-top:0.5rem">
                    @_effectiveEdgeCount relationships is more than can be drawn clearly. Links are hidden;
                    use the relationship list below or Focus mode to explore.
                </p>
            }
            else if (_effectiveEdgeCount == 0)
            {
                <p class="diagram-hint" style="margin-top:0.5rem">
                    No foreign keys were found, so tables are shown without connecting lines. On MySQL,
                    tables using the MyISAM engine do not support foreign keys — only InnoDB relationships appear here.
                </p>
            }

            @* ── FK relationship list (fallback source of truth if a link fails to draw) ── *@
            @if (_effectiveFks.Count > 0)
            {
                <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
                    <div class="profiler-panel-header" style="cursor:default">
                        <span>Foreign Key Relationships</span>
                        <span class="profiler-panel-meta">@_effectiveFks.Count relationship(s) · click to focus</span>
                    </div>
                    <div class="profiler-panel-body">
                        <div class="diagram-fk-grid">
                            @foreach (var fk in _effectiveFks)
                            {
                                <div class="diagram-fk-row diagram-fk-row--clickable"
                                     @onclick="() => FocusOn(Qualify(fk.SchemaName, fk.TableName))"
                                     title="Focus the map on this relationship">
                                    <span class="diagram-fk-label">@fk.SchemaName.@fk.TableName.<strong>@fk.ColumnName</strong></span>
                                    <span class="diagram-fk-arrow">→</span>
                                    <span class="diagram-fk-label">@fk.ReferencedSchema.@fk.ReferencedTable.<strong>@fk.ReferencedColumn</strong></span>
                                    @if (!string.IsNullOrEmpty(fk.ConstraintName))
                                    {
                                        <span class="diagram-fk-constraint">@fk.ConstraintName</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

@code {
    private const int MaxAutoNodes = 150;
    private const int MaxLinks = 400;
    private const double NodeWidth = 220;
    private const double NodeHeight = 40;

    private List<DatabaseObjectInfo> _allObjects = new();
    private List<ForeignKeyInfo> _allFks = new();
    private List<string> _schemaNames = new();
    private readonly HashSet<string> _selectedSchemas = new(StringComparer.OrdinalIgnoreCase);

    private readonly Dictionary<string, EntityMapNode> _nodes = new(StringComparer.OrdinalIgnoreCase);
    private List<DatabaseObjectInfo> _effectiveTables = new();
    private List<ForeignKeyInfo> _effectiveFks = new();
    private int _effectiveEdgeCount;
    private bool _linksSuppressed;
    private bool _tooManyTables;
    private int _visibleTableCount;

    private string _searchTerm = "";
    private CancellationTokenSource? _searchCts;
    private string? _focusRootId;
    private int _focusHops = 1;

    private bool _isLoading = true;
    private BlazorDiagram? _blazorDiagram;
    private bool _diagramReady;
    private int _dbGeneration;

    protected override void OnInitialized()
    {
        SelectorState.OnChange += HandleDatabaseChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogAsync();
        // The first render (and OnAfterRender's initial RebuildMap) usually happens while the
        // catalog is still loading; rebuild again now that the data is here.
        if (_diagramReady)
            RebuildMap();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        _diagramReady = true;
        InitDiagram();
        RebuildMap();
        StateHasChanged();
    }

    public void Dispose()
    {
        SelectorState.OnChange -= HandleDatabaseChanged;
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        DiagramInterop.OnEntityNodeToggle = null;
        DiagramInterop.OnEntityNodeFocus = null;
    }

    private async Task LoadCatalogAsync()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            _allObjects = (await Metadata.GetObjectsAsync())
                .Where(o => o.ObjectType is "TABLE" or "VIEW")
                .OrderBy(o => o.SchemaName).ThenBy(o => o.ObjectName)
                .ToList();

            _allFks = (await Metadata.GetCatalogForeignKeysAsync()).ToList();

            _schemaNames = _allObjects.Select(o => o.SchemaName).Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(s => s, StringComparer.OrdinalIgnoreCase).ToList();

            _selectedSchemas.Clear();
            var defaultSchema = _allObjects
                .GroupBy(o => o.SchemaName, StringComparer.OrdinalIgnoreCase)
                .OrderByDescending(g => g.Count())
                .Select(g => g.Key)
                .FirstOrDefault();
            if (defaultSchema is not null)
                _selectedSchemas.Add(defaultSchema);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void HandleDatabaseChanged()
    {
        var gen = Interlocked.Increment(ref _dbGeneration);
        _ = InvokeAsync(async () =>
        {
            _searchTerm = "";
            _focusRootId = null;
            await LoadCatalogAsync();
            if (gen != _dbGeneration) return;

            InitDiagram();
            RebuildMap();
            StateHasChanged();
        });
    }

    private void InitDiagram()
    {
        // Created once per page; RebuildMap clears and repopulates the layers in place.
        // Recreating the diagram remounts the whole canvas, which is far too heavy to
        // do per search keystroke and orphans nodes mid-interaction.
        if (_blazorDiagram is null)
        {
            _blazorDiagram = new BlazorDiagram();
            _blazorDiagram.RegisterComponent<EntityMapNode, EntityMapNodeWidget>();
        }
        _nodes.Clear();

        DiagramInterop.OnEntityNodeToggle = node => _ = InvokeAsync(() => ToggleNodeAsync(node));
        DiagramInterop.OnEntityNodeFocus = node => _ = InvokeAsync(() =>
        {
            FocusOn(node.QualifiedName);
            StateHasChanged();
        });
    }

    private static string Qualify(string schema, string table) => $"{schema}.{table}";

    private void ToggleSchema(string schema, bool selected)
    {
        if (selected) _selectedSchemas.Add(schema);
        else _selectedSchemas.Remove(schema);
        _focusRootId = null;
        RebuildMap();
    }

    private void OnSearchChanged()
    {
        // Searching takes over from focus mode: the search term defines the visible set.
        if (!string.IsNullOrWhiteSpace(_searchTerm))
            _focusRootId = null;

        // Debounce: rebuilding the map per keystroke is too heavy for large catalogs.
        _searchCts?.Cancel();
        var cts = _searchCts = new CancellationTokenSource();
        _ = DebouncedRebuildAsync(cts.Token);
    }

    private async Task DebouncedRebuildAsync(CancellationToken ct)
    {
        try { await Task.Delay(300, ct); }
        catch (TaskCanceledException) { return; }
        await InvokeAsync(() =>
        {
            RebuildMap();
            StateHasChanged();
        });
    }

    private void FocusOn(string qualifiedId)
    {
        _focusRootId = qualifiedId;
        _searchTerm = "";
        RebuildMap();
    }

    private void ClearFocus()
    {
        _focusRootId = null;
        RebuildMap();
    }

    /// <summary>
    /// Recomputes which tables/edges are in scope (schema filter or focus neighborhood),
    /// applies the large-schema caps, lays out the surviving nodes, and redraws the canvas.
    /// </summary>
    private void RebuildMap()
    {
        if (_blazorDiagram is null) return;

        var allEdges = _allFks
            .Select(fk => new LayoutEdge(Qualify(fk.SchemaName, fk.TableName), Qualify(fk.ReferencedSchema, fk.ReferencedTable)))
            .ToList();

        var term = _searchTerm.Trim();
        List<DatabaseObjectInfo> tables;
        if (_focusRootId is not null)
        {
            var neighborhood = EntityMapGraph.Neighborhood(_focusRootId, _focusHops, allEdges);
            tables = _allObjects.Where(o => neighborhood.Contains(Qualify(o.SchemaName, o.ObjectName))).ToList();
        }
        else if (term.Length > 0)
        {
            // Search filters the visible set across ALL schemas, ignoring the schema checkboxes.
            tables = _allObjects.Where(o => o.ObjectName.Contains(term, StringComparison.OrdinalIgnoreCase)).ToList();
        }
        else
        {
            tables = _allObjects.Where(o => _selectedSchemas.Contains(o.SchemaName)).ToList();
        }

        _effectiveTables = tables;
        _tooManyTables = tables.Count > MaxAutoNodes;
        _visibleTableCount = _tooManyTables ? 0 : tables.Count;

        _blazorDiagram.Links.Clear();
        _blazorDiagram.Nodes.Clear();
        _nodes.Clear();
        if (_tooManyTables)
        {
            _effectiveFks = new();
            _effectiveEdgeCount = 0;
            _linksSuppressed = false;
            return;
        }

        var tableIds = tables.Select(t => Qualify(t.SchemaName, t.ObjectName)).ToHashSet(StringComparer.OrdinalIgnoreCase);
        _effectiveFks = _allFks
            .Where(fk => tableIds.Contains(Qualify(fk.SchemaName, fk.TableName)) &&
                         tableIds.Contains(Qualify(fk.ReferencedSchema, fk.ReferencedTable)))
            .ToList();
        _effectiveEdgeCount = _effectiveFks.Count;
        _linksSuppressed = _effectiveEdgeCount > MaxLinks;

        var edges = _effectiveFks
            .Select(fk => new LayoutEdge(Qualify(fk.SchemaName, fk.TableName), Qualify(fk.ReferencedSchema, fk.ReferencedTable)))
            .ToList();
        var layoutNodes = tables.Select(t => new LayoutNode(Qualify(t.SchemaName, t.ObjectName), NodeWidth, NodeHeight)).ToList();
        var layout = EntityMapLayout.Compute(layoutNodes, edges);

        foreach (var table in tables)
        {
            var id = Qualify(table.SchemaName, table.ObjectName);
            var (x, y) = layout.Positions.TryGetValue(id, out var p) ? p : (0, 0);

            var node = new EntityMapNode(new Point(x, y))
            {
                SchemaName = table.SchemaName,
                TableName = table.ObjectName,
                InDegree = edges.Count(e => string.Equals(e.TargetId, id, StringComparison.OrdinalIgnoreCase)),
                OutDegree = edges.Count(e => string.Equals(e.SourceId, id, StringComparison.OrdinalIgnoreCase)),
            };
            node.FkColumns = _effectiveFks
                .Where(fk => string.Equals(Qualify(fk.SchemaName, fk.TableName), id, StringComparison.OrdinalIgnoreCase))
                .Select(fk => fk.ColumnName)
                .Concat(_effectiveFks
                    .Where(fk => string.Equals(Qualify(fk.ReferencedSchema, fk.ReferencedTable), id, StringComparison.OrdinalIgnoreCase))
                    .Select(fk => fk.ReferencedColumn))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            _blazorDiagram.Nodes.Add(node);
            _nodes[id] = node;
        }

        if (!_linksSuppressed)
        {
            foreach (var fk in _effectiveFks)
            {
                if (!_nodes.TryGetValue(Qualify(fk.SchemaName, fk.TableName), out var child)) continue;
                if (!_nodes.TryGetValue(Qualify(fk.ReferencedSchema, fk.ReferencedTable), out var parent)) continue;

                var link = new LinkModel(new SinglePortAnchor(child.RightPort), new SinglePortAnchor(parent.LeftPort))
                {
                    TargetMarker = LinkMarker.Arrow
                };
                _blazorDiagram.Links.Add(link);
            }
        }

        // In focus mode, make the root table easy to spot.
        if (_focusRootId is not null && _nodes.TryGetValue(_focusRootId, out var root))
            root.Highlighted = true;

        _blazorDiagram.Refresh();
    }

    private async Task ToggleNodeAsync(EntityMapNode node)
    {
        node.IsExpanded = !node.IsExpanded;
        if (node.IsExpanded && node.Columns is null)
        {
            node.IsLoadingColumns = true;
            node.Refresh();
            StateHasChanged();

            node.Columns = (await Metadata.GetColumnsAsync(node.SchemaName, node.TableName)).ToList();
            node.IsLoadingColumns = false;
        }
        node.Refresh();
        StateHasChanged();
    }
}
