@page "/diagram"
@using DbExplorer.Core.Interfaces
@using DbExplorer.Core.Models
@using DbExplorer.Options
@using DbExplorer.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Options
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject IMetadataService Metadata
@inject DatabaseSelectorState SelectorState
@inject DiagramInteropService DiagramInterop
@inject IOptions<QueryBuilderOptions> QBOpts
@inject NavigationManager Nav
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Schema Diagram — DbExplorer</PageTitle>

@if (!QBOpts.Value.Enabled)
{
    <div class="profiler-error">Diagram feature requires Query Builder to be enabled. Set <code>QueryBuilder:Enabled = true</code> in appsettings.json.</div>
    return;
}

<div class="profiler-page">
    <div class="profiler-page-header">
        <h2>Schema Diagram</h2>
        <span class="profiler-connection-badge">
            @SelectorState.Current.Provider — @SelectorState.Current.Name@(SelectorState.SelectedCatalog is not null ? $" / {SelectorState.SelectedCatalog}" : "")
        </span>
    </div>

    <div class="profiler-readonly-notice">
        Add tables to the canvas to see them and their foreign-key relationships. Only the
        tables you pick are drawn, so this stays fast even on large databases.
    </div>

    <div class="diagram-filters">
        <label class="diagram-label">Schema</label>
        @if (_schemas.Count == 0)
        {
            <span class="qb-hint">Loading schemas…</span>
        }
        else
        {
            <select class="qb-select" @bind="_selectedSchema" @bind:after="OnSchemaChangedAsync">
                <option value="">— select schema —</option>
                @foreach (var s in _schemas)
                {
                    <option value="@s.SchemaName">@s.SchemaName</option>
                }
            </select>
        }
        @if (!string.IsNullOrWhiteSpace(_selectedSchema) && !_isLoading)
        {
            <span class="diagram-hint">@_placedCount / @_tables.Count table(s) on canvas</span>
        }
    </div>

    @if (string.IsNullOrWhiteSpace(_selectedSchema))
    {
        <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
            <div class="profiler-panel-body">
                <p class="profiler-empty">Select a schema to begin.</p>
            </div>
        </div>
    }
    else if (_isLoading)
    {
        <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
            <div class="profiler-panel-body">
                <p class="qb-hint"><span class="spinner" aria-hidden="true"></span>Loading schema…</p>
            </div>
        </div>
    }
    else if (_tables.Count == 0)
    {
        <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
            <div class="profiler-panel-body">
                <p class="profiler-empty">No tables found in this schema.</p>
            </div>
        </div>
    }
    else
    {
        @* ── Table palette ── *@
        <div class="diagram-palette">
            <input class="qb-select diagram-palette-filter" placeholder="Filter tables…" @bind="_tableFilter" @bind:event="oninput" />
            <button class="profiler-btn" @onclick="AddAllAsync" disabled="@(_tables.Count > AddAllLimit)">
                Add all (@_tables.Count)
            </button>
            <button class="profiler-btn profiler-btn--ghost" @onclick="ClearCanvas" disabled="@(_placedCount == 0)">Clear canvas</button>
            @if (_tables.Count > AddAllLimit)
            {
                <span class="diagram-hint">Too many tables to add at once — pick individually or filter first.</span>
            }
        </div>
        <div class="diagram-chip-list">
            @foreach (var t in FilteredTables)
            {
                var placed = _nodes.ContainsKey(t.ObjectName);
                <button class="diagram-chip @(placed ? "diagram-chip--placed" : "")"
                        @onclick="() => ToggleTableAsync(t.ObjectName)"
                        title="@(placed ? "Remove from canvas" : "Add to canvas")">
                    <span class="diagram-chip-mark">@(placed ? "✓" : "+")</span>@t.ObjectName
                </button>
            }
        </div>

        @* ── Canvas ── *@
        <div class="diagram-canvas-area" style="margin-top:0.75rem">
            @if (_diagramReady && _blazorDiagram is not null)
            {
                <CascadingValue Value="_blazorDiagram">
                    <DiagramCanvas @key="_blazorDiagram"></DiagramCanvas>
                </CascadingValue>
            }
            else
            {
                <div class="qb-hint">Waiting for the diagram canvas to initialize…</div>
            }
        </div>
        @if (_placedCount == 0)
        {
            <p class="diagram-hint" style="margin-top:0.5rem">Canvas is empty — click a table chip above, or a relationship below, to draw it. Drag a table's header to reposition it.</p>
        }

        @* ── FK relationship list ── *@
        @if (_allForeignKeys.Count > 0)
        {
            <div class="profiler-panel profiler-panel--open" style="margin-top:0.75rem">
                <div class="profiler-panel-header" style="cursor:default">
                    <span>Foreign Key Relationships</span>
                    <span class="profiler-panel-meta">@_allForeignKeys.Count relationship(s) · click to draw</span>
                </div>
                <div class="profiler-panel-body">
                    <div class="diagram-fk-grid">
                        @foreach (var fk in _allForeignKeys)
                        {
                            var bothPlaced = _nodes.ContainsKey(fk.TableName) && _nodes.ContainsKey(fk.ReferencedTable);
                            <div class="diagram-fk-row diagram-fk-row--clickable @(bothPlaced ? "diagram-fk-row--active" : "")"
                                 @onclick="() => AddFkEndpointsAsync(fk)"
                                 title="Add both tables to the canvas">
                                <span class="diagram-fk-label">@fk.SchemaName.@fk.TableName.<strong>@fk.ColumnName</strong></span>
                                <span class="diagram-fk-arrow">→</span>
                                <span class="diagram-fk-label">@fk.ReferencedSchema.@fk.ReferencedTable.<strong>@fk.ReferencedColumn</strong></span>
                                @if (!string.IsNullOrEmpty(fk.ConstraintName))
                                {
                                    <span class="diagram-fk-constraint">@fk.ConstraintName</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<SchemaInfo> _schemas = new();
    private string _selectedSchema = "";
    private List<DatabaseObjectInfo> _tables = new();
    private List<ForeignKeyInfo> _allForeignKeys = new();
    private readonly Dictionary<string, TableDiagramNode> _nodes = new(StringComparer.OrdinalIgnoreCase);
    private string _tableFilter = "";
    private bool _isLoading;

    private BlazorDiagram? _blazorDiagram;
    private bool _diagramReady;
    private int _dbGeneration;

    private const int AddAllLimit = 40;

    private int _placedCount => _nodes.Count;

    private IEnumerable<DatabaseObjectInfo> FilteredTables =>
        string.IsNullOrWhiteSpace(_tableFilter)
            ? _tables
            : _tables.Where(t => t.ObjectName.Contains(_tableFilter, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        SelectorState.OnChange += HandleDatabaseChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        _schemas = (await Metadata.GetSchemasAsync())
            .Where(s => !string.IsNullOrWhiteSpace(s.SchemaName))
            .Select(s => new SchemaInfo(s.SchemaName.Trim()))
            .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _diagramReady = true;
        InitDiagram();
        await EnsureSelectedSchemaAsync();
        StateHasChanged();
    }

    private async Task EnsureSelectedSchemaAsync()
    {
        if (!string.IsNullOrWhiteSpace(_selectedSchema) || _schemas.Count == 0)
            return;

        var currentCatalog = SelectorState.SelectedCatalog;
        if (string.IsNullOrWhiteSpace(currentCatalog))
            currentCatalog = await Metadata.GetCurrentCatalogAsync();

        if (!string.IsNullOrWhiteSpace(currentCatalog) &&
            _schemas.Any(s => string.Equals(s.SchemaName, currentCatalog, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedSchema = currentCatalog!.Trim();
        }
        else if (_schemas.Count > 0)
        {
            _selectedSchema = _schemas[0].SchemaName;
        }

        if (!string.IsNullOrWhiteSpace(_selectedSchema))
        {
            await OnSchemaChangedAsync();
            StateHasChanged();
        }
    }

    private void HandleDatabaseChanged()
    {
        var gen = Interlocked.Increment(ref _dbGeneration);
        _ = InvokeAsync(async () =>
        {
            _selectedSchema = "";
            _tables = new();
            _allForeignKeys = new();
            _tableFilter = "";
            InitDiagram();

            var schemas = (await Metadata.GetSchemasAsync()).ToList();
            if (gen != _dbGeneration) return;

            _schemas = schemas;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SelectorState.OnChange -= HandleDatabaseChanged;
        DiagramInterop.OnNodeRemove = null;
        DiagramInterop.OnGraphChanged = null;
    }

    private void InitDiagram()
    {
        _blazorDiagram = new BlazorDiagram();
        _blazorDiagram.RegisterComponent<TableDiagramNode, TableNodeWidget>();
        _nodes.Clear();

        // The node widget's ✕ button raises OnNodeRemove; wire it to remove the table.
        DiagramInterop.OnNodeRemove = node =>
        {
            if (node is TableDiagramNode t)
                _ = InvokeAsync(() => { RemoveTableNode(t.TableName); StateHasChanged(); });
        };
        DiagramInterop.OnGraphChanged = null;
    }

    private async Task OnSchemaChangedAsync()
    {
        _tables = new();
        _allForeignKeys = new();
        _tableFilter = "";
        InitDiagram();
        StateHasChanged();

        if (string.IsNullOrWhiteSpace(_selectedSchema)) return;
        _selectedSchema = _selectedSchema.Trim();

        _isLoading = true;
        StateHasChanged();
        try
        {
            // Fast: only the table list and the FK map — no per-table column round-trips.
            _tables = (await Metadata.GetObjectsAsync(_selectedSchema))
                .Where(o => o.ObjectType is "TABLE" or "VIEW")
                .OrderBy(t => t.ObjectName)
                .ToList();

            _allForeignKeys = (await Metadata.GetAllForeignKeysAsync(_selectedSchema)).ToList();
        }
        finally
        {
            _isLoading = false;
        }

        StateHasChanged();
    }

    private async Task ToggleTableAsync(string tableName)
    {
        if (_nodes.ContainsKey(tableName))
            RemoveTableNode(tableName);
        else
            await AddTableAsync(tableName);
    }

    private async Task AddTableAsync(string tableName)
    {
        if (_blazorDiagram is null || _nodes.ContainsKey(tableName)) return;

        var i = _nodes.Count;
        const int cols = 4;
        var x = (i % cols) * 280 + 40;
        var y = (i / cols) * 250 + 40;

        var node = new TableDiagramNode($"t{i}", new Point(x, y))
        {
            SchemaName = _selectedSchema,
            TableName = tableName
        };

        var columns = (await Metadata.GetColumnsAsync(_selectedSchema, tableName)).ToList();
        node.SetColumns(columns);

        _blazorDiagram.Nodes.Add(node);
        _nodes[tableName] = node;

        RedrawLinks();
        StateHasChanged();
    }

    private void RemoveTableNode(string tableName)
    {
        if (_blazorDiagram is null || !_nodes.TryGetValue(tableName, out var node)) return;
        _blazorDiagram.Nodes.Remove(node);
        _nodes.Remove(tableName);
        RedrawLinks();
    }

    private async Task AddFkEndpointsAsync(ForeignKeyInfo fk)
    {
        // Both endpoint tables must live in the selected schema to appear on the canvas.
        if (_tables.Any(t => string.Equals(t.ObjectName, fk.TableName, StringComparison.OrdinalIgnoreCase)))
            await AddTableAsync(fk.TableName);
        if (_tables.Any(t => string.Equals(t.ObjectName, fk.ReferencedTable, StringComparison.OrdinalIgnoreCase)))
            await AddTableAsync(fk.ReferencedTable);
    }

    private async Task AddAllAsync()
    {
        if (_tables.Count > AddAllLimit) return;
        foreach (var t in _tables)
            await AddTableAsync(t.ObjectName);
    }

    private void ClearCanvas()
    {
        InitDiagram();
        StateHasChanged();
    }

    /// <summary>
    /// Rebuilds all FK edges between tables currently on the canvas. Links connect the
    /// child table's FK column port to the referenced table's key column port.
    /// </summary>
    private void RedrawLinks()
    {
        if (_blazorDiagram is null) return;

        foreach (var link in _blazorDiagram.Links.ToList())
            _blazorDiagram.Links.Remove(link);

        foreach (var fk in _allForeignKeys)
        {
            if (!_nodes.TryGetValue(fk.TableName, out var child)) continue;
            if (!_nodes.TryGetValue(fk.ReferencedTable, out var parent)) continue;

            var srcPort = child.GetPortForColumn(fk.ColumnName) ?? child.GetLeftPortForColumn(fk.ColumnName);
            var tgtPort = parent.GetLeftPortForColumn(fk.ReferencedColumn) ?? parent.GetPortForColumn(fk.ReferencedColumn);
            if (srcPort is null || tgtPort is null) continue;

            var link = new LinkModel(new SinglePortAnchor(srcPort), new SinglePortAnchor(tgtPort))
            {
                TargetMarker = LinkMarker.Arrow
            };
            _blazorDiagram.Links.Add(link);
        }

        _blazorDiagram.Refresh();
    }
}
