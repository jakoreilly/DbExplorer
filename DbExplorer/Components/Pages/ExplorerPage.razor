@page "/explore/{SchemaName}/{ObjectName}"
@using DbExplorer.Core.Interfaces
@using DbExplorer.Core.Models
@using Microsoft.AspNetCore.Components.Web
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject IMetadataService MetadataService
@inject IDataBrowsingService DataService
@inject NavigationManager Nav
@inject ILogger<ExplorerPage> Logger
@inject IJSRuntime JS
@inject DatabaseSelectorState SelectorState
@inject ISystemAnalyserStore Analyser
@inject DbExplorer.Services.RecentlyViewedState RecentlyViewedState
@inject DbExplorer.Services.PinnedState PinnedState
@rendermode InteractiveServer

<PageTitle>@SchemaName.@ObjectName — DbExplorer</PageTitle>

<div class="explorer-page">
    <div class="object-header">
        <h2><span class="schema-part">@SchemaName.</span><strong>@ObjectName</strong></h2>
        @if (objectType is not null)
        {
            <span class="type-badge type-badge--@objectType">@objectType.Replace('_', ' ')</span>
        }
        <button class="icon-btn @(isPinned ? "icon-btn--active" : "")" type="button" @onclick="TogglePin"
                title="@(isPinned ? "Unpin from sidebar" : "Pin to sidebar")"
                aria-label="@(isPinned ? "Unpin from sidebar" : "Pin to sidebar")"
                aria-pressed="@isPinned.ToString().ToLowerInvariant()">
            <svg viewBox="0 0 24 24" fill="@(isPinned ? "currentColor" : "none")" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 17v5M9 4h6l-.6 6.1 2.6 2.9H7l2.6-2.9L9 4Z" />
            </svg>
        </button>
    </div>

    <div class="tabs">
        <button class="tab @ActiveTab("columns")" @onclick='() => tab = "columns"'>Columns @Badge(columns?.Count)</button>
        @if (objectType is "TABLE")
        {
            <button class="tab @ActiveTab("indexes")" @onclick='() => tab = "indexes"'>Indexes @Badge(indexes?.Count)</button>
            <button class="tab @ActiveTab("fkeys")" @onclick='() => tab = "fkeys"'>Foreign Keys @Badge(foreignKeys?.Count)</button>
            <button class="tab @ActiveTab("triggers")" @onclick='() => tab = "triggers"'>Triggers @Badge(triggers?.Count)</button>
        }
        @if (objectType is "VIEW" or "PROCEDURE" or "SCALAR_FUNCTION" or "TABLE_FUNCTION")
        {
            <button class="tab @ActiveTab("definition")" @onclick='() => tab = "definition"'>Definition</button>
        }
        @if (objectType is "TABLE" or "VIEW")
        {
            <button class="tab @ActiveTab("data")" @onclick='() => tab = "data"'>Data</button>
        }
    </div>

    @if (isLoading)
    {
        <div class="loading"><span class="spinner" aria-hidden="true"></span> Loading…</div>
    }
    else if (error is not null)
    {
        <div class="error">@error</div>
    }
    else
    {
        @switch (tab)
        {
            case "columns":
                <ColumnsPanel Columns="columns" />
                break;
            case "indexes":
                <IndexesPanel Indexes="indexes" />
                break;
            case "fkeys":
                <ForeignKeysPanel ForeignKeys="foreignKeys" />
                break;
            case "triggers":
                <TriggersPanel Triggers="triggers" />
                break;
            case "definition":
                <DefinitionPanel Definition="definition" />
                break;
            case "data":
                <DataGrid SchemaName="@SchemaName" ObjectName="@ObjectName" />
                break;
        }
    }
</div>

@code {
    [Parameter] public string SchemaName { get; set; } = "";
    [Parameter] public string ObjectName { get; set; } = "";

    private string tab = "columns";
    private string? objectType;
    private IReadOnlyList<ColumnInfo>? columns;
    private IReadOnlyList<IndexInfo>? indexes;
    private IReadOnlyList<ForeignKeyInfo>? foreignKeys;
    private IReadOnlyList<TriggerInfo>? triggers;
    private ObjectDefinition? definition;
    private bool isLoading = true;
    private string? error;
    private bool isPinned;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        error = null;
        tab = "columns";
        isPinned = false;

        try
        {
            var allObjects = await MetadataService.GetObjectsAsync(SchemaName);
            var obj = allObjects.FirstOrDefault(o =>
                string.Equals(o.ObjectName, ObjectName, StringComparison.OrdinalIgnoreCase));
            objectType = obj?.ObjectType;

            tab = objectType switch
            {
                "TABLE" or "VIEW" => "data",
                "PROCEDURE" or "SCALAR_FUNCTION" or "TABLE_FUNCTION" => "definition",
                _ => "columns"
            };

            columns = await MetadataService.GetColumnsAsync(SchemaName, ObjectName);

            if (objectType is "TABLE")
            {
                indexes = await MetadataService.GetIndexesAsync(SchemaName, ObjectName);
                foreignKeys = await MetadataService.GetForeignKeysAsync(SchemaName, ObjectName);
                triggers = await MetadataService.GetTriggersAsync(SchemaName, ObjectName);
            }

            if (objectType is "VIEW" or "PROCEDURE" or "SCALAR_FUNCTION" or "TABLE_FUNCTION")
            {
                definition = await MetadataService.GetObjectDefinitionAsync(SchemaName, ObjectName);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading metadata for {Schema}.{Object}", SchemaName, ObjectName);
            error = "Failed to load object metadata. Please try again.";
            Analyser.RecordError(SelectorState.Current.Provider.ToString(), DbActionCategory.Metadata, "LoadObjectMetadata", ex, SchemaName, ObjectName);
        }
        finally
        {
            isLoading = false;
        }

        // Record this object in the recently viewed list stored in localStorage
        if (error is null && objectType is not null)
        {
            try
            {
                await JS.InvokeVoidAsync("dbExplorerAddRecent", SchemaName, ObjectName, objectType, SelectorState.Current.Name);
                RecentlyViewedState.NotifyItemAdded();
                isPinned = await JS.InvokeAsync<bool>("dbExplorerIsPinned", SelectorState.Current.Name, SchemaName, ObjectName);
            }
            catch { /* Non-critical; JS may not be available during pre-render */ }
        }
    }

    private async Task TogglePin()
    {
        if (objectType is null) return;
        try
        {
            isPinned = await JS.InvokeAsync<bool>("dbExplorerTogglePinned",
                SelectorState.Current.Name, SchemaName, ObjectName, objectType);
            PinnedState.NotifyChanged();
        }
        catch { }
    }

    private string ActiveTab(string name) => tab == name ? "active" : "";

    private RenderFragment? Badge(int? count) => count is > 0
        ? @<span class="tab-badge">@count</span>
        : null;
}
