@using DbExplorer.Services
@inject ThemeState ThemeState
@inject IJSRuntime JS

<button class="theme-toggle" type="button" @onclick="ToggleTheme">
    @ButtonText
</button>

@code {
    private string ButtonText => ThemeState.IsDarkMode ? "Light Mode" : "Dark Mode";

    private async Task ToggleTheme()
    {
        ThemeState.Toggle();
        try { await JS.InvokeVoidAsync("dbExplorerSetTheme", ThemeState.IsDarkMode); }
        catch { }
    }
}
