@using DbExplorer.Core.Models

<div class="panel triggers-panel">
    @if (Triggers is null || Triggers.Count == 0)
    {
        <div class="empty-state">
            <span class="empty-state-icon" aria-hidden="true">⚙</span>
            No triggers found.
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Trigger Name</th>
                    <th>Events</th>
                    <th>Enabled</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var trig in Triggers)
                {
                    <tr>
                        <td><strong>@trig.TriggerName</strong></td>
                        <td class="cell-mono">@trig.Events</td>
                        <td><span class="pill @(trig.IsEnabled ? "pill--yes" : "pill--no")">@(trig.IsEnabled ? "ENABLED" : "DISABLED")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<TriggerInfo>? Triggers { get; set; }
}
