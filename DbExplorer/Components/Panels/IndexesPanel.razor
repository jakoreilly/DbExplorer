@using DbExplorer.Core.Models

<div class="panel indexes-panel">
    @if (Indexes is null || Indexes.Count == 0)
    {
        <div class="empty-state">
            <span class="empty-state-icon" aria-hidden="true">⚡</span>
            No indexes found.
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Index Name</th>
                    <th>Columns</th>
                    <th>Unique</th>
                    <th>Primary Key</th>
                    <th>Clustered</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var idx in Indexes)
                {
                    <tr>
                        <td><strong>@idx.IndexName</strong></td>
                        <td class="cell-mono">@idx.Columns</td>
                        <td><span class="pill @(idx.IsUnique ? "pill--yes" : "pill--no")">@(idx.IsUnique ? "YES" : "NO")</span></td>
                        <td>
                            @if (idx.IsPrimaryKey)
                            {
                                <span class="pill pill--pk">PK</span>
                            }
                        </td>
                        <td><span class="pill @(idx.IsClustered ? "pill--yes" : "pill--no")">@(idx.IsClustered ? "YES" : "NO")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<IndexInfo>? Indexes { get; set; }
}
