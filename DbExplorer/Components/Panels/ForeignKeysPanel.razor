@using DbExplorer.Core.Models
@inject NavigationManager Nav

<div class="panel fkeys-panel">
    @if (ForeignKeys is null || ForeignKeys.Count == 0)
    {
        <div class="empty-state">
            <span class="empty-state-icon" aria-hidden="true">🔗</span>
            No foreign keys found.
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Constraint</th>
                    <th>Column</th>
                    <th>References</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fk in ForeignKeys)
                {
                    <tr>
                        <td><strong>@fk.ConstraintName</strong></td>
                        <td class="cell-mono">@fk.ColumnName</td>
                        <td>
                            <a href="@ExploreUrl(fk)" title="Open @fk.ReferencedSchema.@fk.ReferencedTable">
                                @fk.ReferencedSchema.@fk.ReferencedTable</a>
                            <span class="cell-mono"> (@fk.ReferencedColumn)</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<ForeignKeyInfo>? ForeignKeys { get; set; }

    private static string ExploreUrl(ForeignKeyInfo fk) =>
        $"/explore/{Uri.EscapeDataString(fk.ReferencedSchema)}/{Uri.EscapeDataString(fk.ReferencedTable)}";
}
